<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="mkt_0901_view_paf_pspd_line_list" model="ir.ui.view">
        <field name="name">mkt_paf.pspd.line.list</field>
        <field name="model">mkt_paf.pspd.line</field>
        <field name="arch" type="xml">
            <list string="PAF PSPD Forecast">
                <field name="paf_request_id"/>
                <field name="store_id"/>
                <field name="date"/>
                <field name="forecast_qty"/>
                <field name="forecast_revenue"/>
                <field name="weight_factor"/>
            </list>
        </field>
    </record>

    <record id="mkt_0901_view_paf_pspd_line_form" model="ir.ui.view">
        <field name="name">mkt_paf.pspd.line.form</field>
        <field name="model">mkt_paf.pspd.line</field>
        <field name="arch" type="xml">
            <form string="PAF PSPD Forecast">
                <sheet>
                    <group>
                        <field name="paf_request_id"/>
                        <field name="store_id"/>
                        <field name="date"/>
                        <field name="forecast_qty"/>
                        <field name="forecast_revenue"/>
                        <field name="currency_id" invisible="1"/>
                        <field name="weight_factor"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="mkt_0901_view_paf_pspd_line_search" model="ir.ui.view">
        <field name="name">mkt_paf.pspd.line.search</field>
        <field name="model">mkt_paf.pspd.line</field>
        <field name="arch" type="xml">
            <search string="Search PSPD Forecast">
                <field name="paf_request_id"/>
                <field name="store_id"/>
                <field name="date"/>
                <filter string="PAF Request" name="group_by_request" context="{'group_by': 'paf_request_id'}"/>
                <filter string="Store" name="group_by_store" context="{'group_by': 'store_id'}"/>
                <filter string="Date" name="group_by_date" context="{'group_by': 'date'}"/>
            </search>
        </field>
    </record>

    <record id="mkt_0901_action_paf_pspd_line" model="ir.actions.act_window">
        <field name="name">PSPD Forecast</field>
        <field name="res_model">mkt_paf.pspd.line</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="mkt_0901_view_paf_pspd_line_search"/>
    </record>

    <record id="mkt_0901_view_paf_pspd_wizard_form" model="ir.ui.view">
        <field name="name">mkt_paf.pspd.wizard.form</field>
        <field name="model">mkt_paf.pspd.wizard</field>
        <field name="arch" type="xml">
            <form string="Distribute PSPD">
                <group>
                    <field name="paf_request_id"/>
                    <field name="algorithm"/>
                    <field name="total_target_qty"/>
                </group>
                <footer>
                    <button name="action_distribute" string="Distribute" type="object" class="btn-primary"/>
                    <button string="Cancel" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <menuitem id="mkt_0901_menu_pspd_forecast"
              name="PSPD Forecast"
              parent="mkt_0901_menu_root"
              action="mkt_0901_action_paf_pspd_line"
              sequence="55"/>
</odoo>

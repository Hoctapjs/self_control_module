<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_product_template_form_inherit_paf" model="ir.ui.view">
        <field name="name">product.template.form.inherit.paf</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='purchase']" position="inside">
                <group string="Cấu hình PAF" name="paf_config">
                    <field name="paf_can_use"/>
                    <field name="paf_last_cost" readonly="1"/>
                    <field name="food_safety_declaration_state"/>
                    <field name="food_safety_declaration_no"/>
                    <field name="food_safety_declaration_date"/>
                    <field name="food_safety_notes"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>

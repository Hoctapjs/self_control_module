<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Inherit Approval Request Form View to add PAF request integration -->
    <record id="mkt_0901_view_approval_request_form_inherit" model="ir.ui.view">
        <field name="name">approval.request.form.inherit.mkt.paf</field>
        <field name="model">approval.request</field>
        <field name="inherit_id" ref="approvals.approval_request_view_form"/>
        <field name="arch" type="xml">
            <!-- Add smart button to button box -->
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_open_paf_request" type="object" class="oe_stat_button" icon="fa-file-text" invisible="not x_psm_mkt_paf_request_id">
                    <div class="o_field_widget o_stat_info">
                        <span class="o_stat_text">PAF Request</span>
                    </div>
                </button>
            </xpath>

            <!-- Add tab to notebook -->
            <xpath expr="//notebook" position="inside">
                <page string="Marketing PAF" name="mkt_paf" invisible="not x_psm_mkt_paf_request_id">
                    <group>
                        <group string="Liên kết PAF">
                            <field name="x_psm_mkt_paf_request_id" readonly="1"/>
                        </group>
                    </group>
                    <div class="oe_button_box" style="margin-top: 10px;">
                        <button name="action_open_paf_request" string="Mở PAF Request" type="object" class="oe_highlight"/>
                    </div>
                </page>
            </xpath>
        </field>
    </record>

    <!-- Inherit Approval Category Form View to add PAF configurations -->
    <record id="mkt_0901_view_approval_category_form_inherit" model="ir.ui.view">
        <field name="name">approval.category.form.inherit.mkt.paf</field>
        <field name="model">approval.category</field>
        <field name="inherit_id" ref="approvals.approval_category_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//group[@name='option_settings']" position="inside">
                <field name="is_mkt_paf"/>
                <field name="mkt_paf_stage" invisible="not is_mkt_paf" required="is_mkt_paf"/>
            </xpath>
        </field>
    </record>
</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Template Tree/List View -->
    <record id="mkt_0901_view_paf_template_tree" model="ir.ui.view">
        <field name="name">mkt_paf.template.list</field>
        <field name="model">mkt_paf.template</field>
        <field name="arch" type="xml">
            <list string="PAF Templates" sample="1">
                <field name="name"/>
                <field name="code"/>
                <field name="default_loyalty_program_id"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <!-- Template Form View -->
    <record id="mkt_0901_view_paf_template_form" model="ir.ui.view">
        <field name="name">mkt_paf.template.form</field>
        <field name="model">mkt_paf.template</field>
        <field name="arch" type="xml">
            <form string="PAF Template">
                <sheet>
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger" invisible="active"/>
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only"/>
                        <h1>
                            <field name="name" placeholder="Ví dụ: PAF Sản Phẩm Mới Mùa Hè"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="code" placeholder="Ví dụ: PAF-SUMMER"/>
                            <field name="default_loyalty_program_id" options="{'no_create': True}"/>
                            <field name="active" widget="boolean_toggle"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Sản phẩm &amp; Đánh giá" name="products_evaluation">
                            <group>
                                <field name="default_product_ids" widget="many2many_tags" placeholder="Chọn sản phẩm mặc định..." options="{'no_create': True}"/>
                                <field name="required_dept_evaluation" widget="many2many_tags" placeholder="Chọn các phòng ban cần đánh giá..."/>
                            </group>
                        </page>
                        <page string="Khung mẫu pháp lý" name="legal_defaults">
                            <group>
                                <group string="Pháp lý khuyến mãi">
                                    <field name="default_promotion_type"/>
                                    <field name="default_promotion_legal_form" readonly="default_promotion_type == 'lucky_draw'"/>
                                    <field name="default_eligible_channel_ids" widget="many2many_tags" options="{'no_create': True}"/>
                                </group>
                                <group string="Thể lệ">
                                    <field name="default_max_uses_per_customer"/>
                                    <field name="default_time_window_start"/>
                                    <field name="default_time_window_end"/>
                                    <field name="default_food_safety_responsible_dept_id" options="{'no_create': True}"/>
                                </group>
                            </group>
                            <group string="Mô tả pháp lý mặc định">
                                <field name="default_description_legal_html" widget="html" options="{'safe': True}" nolabel="1"/>
                            </group>
                        </page>
                        <page string="Mô tả mẫu" name="description">
                            <field name="description_html" widget="html" options="{'safe': True}"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Template Search View -->
    <record id="mkt_0901_view_paf_template_search" model="ir.ui.view">
        <field name="name">mkt_paf.template.search</field>
        <field name="model">mkt_paf.template</field>
        <field name="arch" type="xml">
            <search string="Tìm kiếm PAF Templates">
                <field name="name"/>
                <field name="code"/>
                <filter string="Lưu trữ" name="inactive" domain="[('active', '=', False)]"/>
            </search>
        </field>
    </record>

    <!-- Template Action -->
    <record id="mkt_0901_action_paf_template" model="ir.actions.act_window">
        <field name="name">PAF Templates</field>
        <field name="res_model">mkt_paf.template</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="mkt_0901_view_paf_template_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Tạo PAF Template mới
            </p>
            <p>
                Templates định nghĩa các cấu hình mặc định (phần thưởng, sản phẩm, phòng ban đánh giá) cho quy trình phê duyệt PAF.
            </p>
        </field>
    </record>

</odoo>

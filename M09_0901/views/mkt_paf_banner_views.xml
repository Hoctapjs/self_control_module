<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="mkt_0901_view_paf_banner_kanban" model="ir.ui.view">
        <field name="name">mkt_paf.banner.kanban</field>
        <field name="model">mkt_paf.banner</field>
        <field name="arch" type="xml">
            <kanban>
                <field name="image"/>
                <field name="name"/>
                <field name="purpose"/>
                <field name="status"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_global_click">
                            <div class="o_kanban_image">
                                <field name="image" widget="image"/>
                            </div>
                            <div class="oe_kanban_details">
                                <strong><field name="name"/></strong>
                                <div><field name="purpose"/></div>
                                <div><field name="status" widget="badge"/></div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="mkt_0901_view_paf_banner_list" model="ir.ui.view">
        <field name="name">mkt_paf.banner.list</field>
        <field name="model">mkt_paf.banner</field>
        <field name="arch" type="xml">
            <list string="PAF Banners">
                <field name="sequence" widget="handle"/>
                <field name="image" widget="image" options="{'size': [60, 60]}"/>
                <field name="name"/>
                <field name="paf_request_id"/>
                <field name="purpose"/>
                <field name="language"/>
                <field name="target_dimensions"/>
                <field name="actual_dimensions"/>
                <field name="file_size_kb"/>
                <field name="status" widget="badge"
                       decoration-success="status == 'brand_approved'"
                       decoration-danger="status == 'rejected'"/>
            </list>
        </field>
    </record>

    <record id="mkt_0901_view_paf_banner_form" model="ir.ui.view">
        <field name="name">mkt_paf.banner.form</field>
        <field name="model">mkt_paf.banner</field>
        <field name="arch" type="xml">
            <form string="PAF Banner">
                <header>
                    <button name="action_brand_approve" string="Brand Approve" type="object" class="oe_highlight" invisible="status != 'draft'" groups="M09_0901.MKT_0901_brand_reviewer,M09_0901.MKT_0901_admin"/>
                    <button name="action_brand_reject" string="Brand Reject" type="object" class="btn-danger" invisible="status != 'draft'" groups="M09_0901.MKT_0901_brand_reviewer,M09_0901.MKT_0901_admin"/>
                    <button name="action_reset_draft" string="Reset Draft" type="object" invisible="status != 'rejected'"/>
                    <field name="status" widget="statusbar" statusbar_visible="draft,brand_approved,rejected"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="paf_request_id"/>
                            <field name="name"/>
                            <field name="image" widget="image" filename="image_filename"/>
                            <field name="image_filename" invisible="1"/>
                        </group>
                        <group>
                            <field name="purpose"/>
                            <field name="platform_id" options="{'no_create': True}"/>
                            <field name="language"/>
                            <field name="target_dimensions"/>
                            <field name="target_dpi"/>
                            <field name="actual_dimensions"/>
                            <field name="file_size_kb"/>
                        </group>
                    </group>
                    <group>
                        <group string="Duyệt">
                            <field name="approver_id"/>
                            <field name="approval_date"/>
                            <field name="rejection_reason"/>
                        </group>
                        <group string="Ghi chú">
                            <field name="notes"/>
                        </group>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="mkt_0901_action_paf_banner" model="ir.actions.act_window">
        <field name="name">PAF Banners</field>
        <field name="res_model">mkt_paf.banner</field>
        <field name="view_mode">kanban,list,form</field>
    </record>
</odoo>

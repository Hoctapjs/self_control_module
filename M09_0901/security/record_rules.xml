<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Record rule for department evaluation line restriction -->
    <record id="mkt_0901_rule_paf_evaluation_line_dept" model="ir.rule">
        <field name="name">PAF Evaluation Line - Dept Restriction</field>
        <field name="model_id" ref="model_mkt_paf_evaluation_line"/>
        <field name="domain_force">[('department_id', 'in', user.employee_ids.department_id.ids)]</field>
        <field name="groups" eval="[(4, ref('MKT_0901_si_analyst')),
                                   (4, ref('MKT_0901_ops_evaluator')),
                                   (4, ref('MKT_0901_finance_evaluator')),
                                   (4, ref('MKT_0901_sc_evaluator')),
                                   (4, ref('MKT_0901_legal_evaluator'))]"/>
    </record>

    <!-- Admin bypass rule to see all lines -->
    <record id="mkt_0901_rule_paf_evaluation_line_see_all" model="ir.rule">
        <field name="name">PAF Evaluation Line - See All</field>
        <field name="model_id" ref="model_mkt_paf_evaluation_line"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('MKT_0901_creator')),
                                   (4, ref('MKT_0901_approver_head')),
                                   (4, ref('MKT_0901_clevel_approver')),
                                   (4, ref('MKT_0901_admin'))]"/>
    </record>
</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Record Rule cho Stock Picking: Portal user chỉ xem được phiếu kho incoming của chính họ -->
        <record id="stock_picking_portal_rule" model="ir.rule">
            <field name="name">Portal Vendor: Read own incoming pickings</field>
            <field name="model_id" ref="stock.model_stock_picking"/>
            <field name="domain_force">[('partner_id', '=', user.partner_id.id), ('picking_type_id.code', '=', 'incoming')]</field>
            <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- Record Rule cho Stock Move: Portal user chỉ xem được chi tiết kho của phiếu kho incoming của họ -->
        <record id="stock_move_portal_rule" model="ir.rule">
            <field name="name">Portal Vendor: Read own incoming stock moves</field>
            <field name="model_id" ref="stock.model_stock_move"/>
            <field name="domain_force">[('picking_id.partner_id', '=', user.partner_id.id), ('picking_id.picking_type_id.code', '=', 'incoming')]</field>
            <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>
    </data>
</odoo>

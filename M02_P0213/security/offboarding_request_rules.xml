<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
        <!--
            0213 uses 0200 organization groups to grant business access on the
            offboarding approval flow without changing the generic ACLs of
            shared models such as approval.request and approval.approver.
        -->

        <record id="rule_0213_approval_request_ops_read" model="ir.rule">
            <field name="name">0213 approval.request OPS read scope</field>
            <field name="model_id" ref="approvals.model_approval_request"/>
            <field name="groups" eval="[
                (6, 0, [
                    ref('M02_P0200.GDH_RST_OPS_OC_S'),
                    ref('M02_P0200.GDH_RST_OPS_OM_M')
                ])
            ]"/>
            <field name="domain_force">[('category_id.x_psm_0213_is_offboarding', '=', True)]</field>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <record id="rule_0213_approval_request_hr_read" model="ir.rule">
            <field name="name">0213 approval.request HR read scope</field>
            <field name="model_id" ref="approvals.model_approval_request"/>
            <field name="groups" eval="[
                (6, 0, [
                    ref('M02_P0200.GDH_RST_HR_ADMIN_S'),
                    ref('M02_P0200.GDH_RST_HR_ADMIN_M'),
                    ref('M02_P0200.GDH_RST_HR_HRBP_S'),
                    ref('M02_P0200.GDH_RST_HR_HRBP_M'),
                    ref('M02_P0200.GDH_RST_HR_HEAD_M'),
                    ref('M02_P0200.GDH_RST_SYSTEM_ST_M')
                ])
            ]"/>
            <field name="domain_force">[('category_id.x_psm_0213_is_offboarding', '=', True)]</field>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <record id="rule_0213_approval_request_hr_write" model="ir.rule">
            <field name="name">0213 approval.request HR write scope</field>
            <field name="model_id" ref="approvals.model_approval_request"/>
            <field name="groups" eval="[
                (6, 0, [
                    ref('M02_P0200.GDH_RST_HR_ADMIN_S'),
                    ref('M02_P0200.GDH_RST_HR_ADMIN_M'),
                    ref('M02_P0200.GDH_RST_HR_HRBP_M'),
                    ref('M02_P0200.GDH_RST_HR_HEAD_M'),
                    ref('M02_P0200.GDH_RST_SYSTEM_ST_M')
                ])
            ]"/>
            <field name="domain_force">[('category_id.x_psm_0213_is_offboarding', '=', True)]</field>
            <field name="perm_read" eval="False"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <record id="rule_0213_approval_approver_scope_read" model="ir.rule">
            <field name="name">0213 approval.approver scope read</field>
            <field name="model_id" ref="approvals.model_approval_approver"/>
            <field name="groups" eval="[
                (6, 0, [
                    ref('M02_P0200.GDH_RST_OPS_OC_S'),
                    ref('M02_P0200.GDH_RST_OPS_OM_M'),
                    ref('M02_P0200.GDH_RST_HR_ADMIN_S'),
                    ref('M02_P0200.GDH_RST_HR_ADMIN_M'),
                    ref('M02_P0200.GDH_RST_HR_HRBP_S'),
                    ref('M02_P0200.GDH_RST_HR_HRBP_M'),
                    ref('M02_P0200.GDH_RST_HR_HEAD_M'),
                    ref('M02_P0200.GDH_RST_SYSTEM_ST_M')
                ])
            ]"/>
            <field name="domain_force">[('request_id.category_id.x_psm_0213_is_offboarding', '=', True)]</field>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <record id="rule_0213_mail_activity_scope_read" model="ir.rule">
            <field name="name">0213 mail.activity scope read</field>
            <field name="model_id" ref="mail.model_mail_activity"/>
            <field name="groups" eval="[
                (6, 0, [
                    ref('M02_P0200.GDH_RST_OPS_OC_S'),
                    ref('M02_P0200.GDH_RST_OPS_OM_M'),
                    ref('M02_P0200.GDH_RST_HR_ADMIN_S'),
                    ref('M02_P0200.GDH_RST_HR_ADMIN_M'),
                    ref('M02_P0200.GDH_RST_HR_HRBP_S'),
                    ref('M02_P0200.GDH_RST_HR_HRBP_M'),
                    ref('M02_P0200.GDH_RST_HR_HEAD_M'),
                    ref('M02_P0200.GDH_RST_SYSTEM_ST_M')
                ])
            ]"/>
            <field name="domain_force">[('x_psm_0213_is_offboarding_activity', '=', True)]</field>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <record id="rule_0213_mail_activity_hr_write" model="ir.rule">
            <field name="name">0213 mail.activity HR write scope</field>
            <field name="model_id" ref="mail.model_mail_activity"/>
            <field name="groups" eval="[
                (6, 0, [
                    ref('M02_P0200.GDH_RST_HR_ADMIN_S'),
                    ref('M02_P0200.GDH_RST_HR_ADMIN_M'),
                    ref('M02_P0200.GDH_RST_HR_HEAD_M'),
                    ref('M02_P0200.GDH_RST_SYSTEM_ST_M')
                ])
            ]"/>
            <field name="domain_force">[('x_psm_0213_is_offboarding_activity', '=', True)]</field>
            <field name="perm_read" eval="False"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>
    </data>
</odoo>

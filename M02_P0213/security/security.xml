        <record id="rule_0213_survey_internal_read" model="ir.rule">
            <field name="name">0213 internal chi xem survey exit interview</field>
            <field name="model_id" ref="survey.model_survey_survey"/>
            <field name="groups" eval="[
                (6, 0, [
                    ref('base.group_user'),
                    ref('M02_P0200.GDH_RST_OPS_OM_M'),
                    ref('M02_P0200.GDH_RST_HR_ADMIN_S'),
                    ref('M02_P0200.GDH_RST_HR_ADMIN_M'),
                    ref('M02_P0200.GDH_RST_HR_HRBP_S'),
                    ref('M02_P0200.GDH_RST_HR_HRBP_M'),
                    ref('M02_P0200.GDH_RST_HR_HEAD_M'),
                    ref('M02_P0200.GDH_RST_SYSTEM_ST_M')
                ])
            ]"/>
            <field name="domain_force" eval="[('id', '=', ref('M02_P0213.psm_0213_survey_exit_interview'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>


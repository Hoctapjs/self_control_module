<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="view_psm_0213_resignation_portal_template" name="Form yêu cầu nghỉ việc">
        <t t-call="portal.portal_layout">
            <style>
                .o_psm_0213_portal {
                    color: var(--foreground, #1f2937);
                }

                .o_psm_0213_portal .card,

                html[data-bs-theme='dark'] .o_psm_0213_portal h5,
                html[data-bs-theme='dark'] .o_psm_0213_portal h6,
                html[data-bs-theme='dark'] .o_psm_0213_portal .card-title,
                html[data-bs-theme='dark'] .o_psm_0213_portal .theme-survey-title,
                html[data-bs-theme='dark'] .o_psm_0213_portal .theme-task-list-title,
                html[data-bs-theme='dark'] .o_psm_0213_portal .theme-task-card h6 {
                    color: #ff5a4f !important;
                    font-family: "Roboto", Arial, sans-serif !important;
                }

                html[data-theme='dark'] .o_psm_0213_portal .psm-alert--approved,
                html[data-theme='dark'] .o_psm_0213_portal .psm-alert--approved i,
                html[data-theme='dark'] .o_psm_0213_portal .psm-alert--approved strong,
                html[data-bs-theme='dark'] .o_psm_0213_portal .psm-alert--approved,
                html[data-bs-theme='dark'] .o_psm_0213_portal .psm-alert--approved i,
                html[data-bs-theme='dark'] .o_psm_0213_portal .psm-alert--approved strong {
                    color: #22c55e !important;
                }

<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
        <record id="psm_0213_email_template_employee_approved_notification" model="mail.template">
            <field name="name">OPS - Thông báo đơn nghỉ việc đã được duyệt</field>
            <field name="model_id" ref="approvals.model_approval_request"/>
            <field name="subject">[RST Offboarding 0213] Đơn nghỉ việc của bạn đã được duyệt</field>
            <field name="email_from">{{ (object.company_id.email or user.email) }}</field>
            <field name="email_to">{{ object.request_owner_id.partner_id.email or object.request_owner_id.email }}</field>
            <field name="body_html" type="html">
                <div style="margin:0;padding:24px 0;background-color:#f4f1ea;font-family:'Segoe UI',Arial,sans-serif;color:#2f2a26;">
                    <table border="0" cellpadding="0" cellspacing="0" width="100%" bgcolor="#f4f1ea" style="border-collapse:collapse;background-color:#f4f1ea;">
                        <tr>
                            <td align="center">
                                <table border="0" cellpadding="0" cellspacing="0" width="640" bgcolor="#fffdf9" style="width:640px;max-width:640px;background-color:#fffdf9;border:1px solid #eadfce;border-radius:18px;overflow:hidden;">
                                    <tr>
                                        <td bgcolor="#2f7d4f" style="padding:26px 32px;background-color:#2f7d4f;">
                                            <div style="font-size:12px;letter-spacing:1.2px;text-transform:uppercase;color:#e8ffd8;font-weight:700;margin-bottom:10px;">OPS Approved</div>
                                            <h1 style="margin:0;font-size:26px;line-height:1.25;color:#ffffff;font-weight:800;">Đơn nghỉ việc của bạn đã được duyệt</h1>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td style="padding:30px 32px 12px 32px;">
                                            <p style="margin:0 0 16px 0;font-size:15px;line-height:1.7;">Kính gửi <strong><t t-out="object.x_psm_0213_employee_id.name or object.request_owner_id.name"/></strong>,</p>
                                            <p style="margin:0 0 18px 0;font-size:15px;line-height:1.7;">
                                                Đơn nghỉ việc OPS của bạn đã được quản lý phê duyệt. Vui lòng theo dõi Portal và hoàn thành các đầu việc offboarding khi được giao.
                                            </p>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td style="padding:0 32px 18px 32px;">
                                            <t t-if="object.x_psm_0213_al_has_advance">
                                                <table border="0" cellpadding="0" cellspacing="0" width="100%" bgcolor="#fff6ed" style="border-collapse:separate;border-spacing:0;background-color:#fff6ed;border:1px solid #f0c9a8;border-radius:16px;">
                                                    <tr>
                                                        <td style="padding:18px 20px;">
                                                            <div style="font-size:13px;font-weight:800;letter-spacing:0.4px;text-transform:uppercase;color:#8f2635;margin-bottom:14px;">Ph&#233;p n&#259;m &#7913;ng tr&#432;&#7899;c</div>
                                                            <p style="margin:0;font-size:24px;line-height:1.2;color:#8f2635;font-weight:800;">
                                                                <t t-out="'%.2f' % object.x_psm_0213_al_advance_days"/> ng&#224;y
                                                            </p>
                                                            <p style="margin:8px 0 0 0;font-size:13px;line-height:1.6;color:#7b3f24;">
                                                                B&#7841;n &#273;&#227; s&#7917; d&#7909;ng v&#432;&#7907;t s&#7889; ph&#233;p n&#259;m. S&#7889; ng&#224;y &#7913;ng tr&#432;&#7899;c s&#7869; &#273;&#432;&#7907;c quy &#273;&#7893;i v&#224; kh&#7845;u tr&#7915; v&#224;o l&#432;&#417;ng quy&#7871;t to&#225;n.
                                                            </p>
                                                        </td>
                                                    </tr>
                                                </table>
                                            </t>
                                            <t t-else="">
                                                <table border="0" cellpadding="0" cellspacing="0" width="100%" bgcolor="#eef8f1" style="border-collapse:separate;border-spacing:0;background-color:#eef8f1;border:1px solid #b8dfc3;border-radius:16px;">
                                                    <tr>
                                                        <td style="padding:18px 20px;">
                                                            <div style="font-size:13px;font-weight:800;letter-spacing:0.4px;text-transform:uppercase;color:#2f7d4f;margin-bottom:14px;">Thông tin phép năm</div>
                                                            <p style="margin:0;font-size:24px;line-height:1.2;color:#1f5c3a;font-weight:800;">
                                                                <t t-out="'%.2f' % object.x_psm_0200_remaining_al_days"/> ngày
                                                            </p>
                                                            <p style="margin:8px 0 0 0;font-size:13px;line-height:1.6;color:#53645a;">
                                                                Số ngày phép năm còn lại được tính tại thời điểm đơn được duyệt.
                                                            </p>
                                                        </td>
                                                    </tr>
                                                </table>
                                            </t>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td style="padding:0 32px 30px 32px;">
                                            <p style="margin:0;font-size:15px;line-height:1.8;">Trân trọng,<br/><strong>Phòng Nhân sự</strong></p>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td bgcolor="#f7f2e8" style="padding:16px 32px;background-color:#f7f2e8;border-top:1px solid #eadfce;">
                                            <p style="margin:0;font-size:12px;line-height:1.6;color:#7b7269;">Email này được gửi tự động từ quy trình offboarding OPS khi đơn nghỉ việc đã được quản lý phê duyệt.</p>
                                        </td>
                                    </tr>
                                </table>
                            </td>
                        </tr>
                    </table>
                </div>
            </field>
            <field name="lang">{{ object.request_owner_id.lang }}</field>
            <field name="auto_delete">True</field>
        </record>
    </data>
</odoo>

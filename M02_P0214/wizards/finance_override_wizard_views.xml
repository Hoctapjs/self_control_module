<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_psm_0214_finance_override_wizard_form" model="ir.ui.view">
        <field name="name">x_psm_0214.finance.override.wizard.form</field>
        <field name="model">x_psm_0214_finance_override_wizard</field>
        <field name="arch" type="xml">
            <form string="Override Accounting Check">
                <group>
                    <field name="request_id" readonly="1"/>
                    <field name="reason" placeholder="Enter override reason..." required="1"/>
                </group>
                <footer>
                    <button name="action_apply" type="object" string="Apply Override"
                            class="btn-primary o_psm_0214_backend_action"/>
                    <button string="Cancel" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>

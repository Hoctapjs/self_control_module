<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
        <record id="email_template_social_insurance" model="mail.template">
            <field name="name">[HR] Nhận Sổ/Tờ rời BHXH và Quyết Định Nghỉ việc</field>
            <field name="model_id" ref="approvals.model_approval_request"/>
            <field name="subject">[HR] Nhận Sổ/Tờ rời BHXH và Quyết Định Nghỉ việc</field>
            <field name="email_from">{{ (object.company_id.email or object.x_psm_0214_employee_id.company_id.email or user.email_formatted) }}</field>
            <field name="email_to">{{ object.x_psm_0214_employee_id.work_email or object.x_psm_0214_employee_id.user_id.email or object.x_psm_0214_employee_id.private_email or object.request_owner_id.partner_id.email or object.request_owner_id.email }}</field>
            <field name="body_html" type="html">
                <div style="margin:0;padding:18px 0;background-color:#f4f1ea;font-family:'Segoe UI',Arial,sans-serif;color:#2f2a26;">
                    <table border="0" cellpadding="0" cellspacing="0" width="100%" bgcolor="#f4f1ea" style="border-collapse:collapse;background-color:#f4f1ea;">
                        <tr>
                            <td align="center">
                                <table border="0" cellpadding="0" cellspacing="0" width="640" bgcolor="#fffdf9" style="width:640px;max-width:640px;background-color:#fffdf9;border:1px solid #eadfce;border-radius:20px;overflow:hidden;">
                                    <tr>
                                        <td bgcolor="#b5121b" style="padding:0;background-color:#b5121b;">
                                            <table border="0" cellpadding="0" cellspacing="0" width="100%" bgcolor="#b5121b" style="background-color:#b5121b;">
                                                <tr>
                                                    <td style="padding:24px 28px 18px 28px;">
                                                        <div style="font-size:11px;letter-spacing:1.1px;text-transform:uppercase;color:#ffe7a3;font-weight:700;margin-bottom:8px;">HR Support</div>
                                                        <h1 style="margin:0;font-size:24px;line-height:1.3;color:#ffffff;font-weight:800;">Nhận hồ sơ BHXH và quyết định nghỉ việc</h1>
                                                        <p style="margin:8px 0 0 0;font-size:13px;line-height:1.6;color:#fff4da;">Phòng Nhân sự cần xác nhận thông tin nhận hồ sơ để sắp xếp gửi chứng từ nghỉ việc đến đúng địa chỉ của anh/chị.</p>
                                                    </td>
                                                </tr>
                                            </table>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td style="padding:24px 28px 10px 28px;">
                                            <p style="margin:0 0 14px 0;font-size:14px;line-height:1.7;">Kính gửi anh/chị <strong><t t-out="object.x_psm_0214_employee_id.name or object.request_owner_id.name"/></strong>,</p>
                                            <p style="margin:0 0 16px 0;font-size:14px;line-height:1.7;">Sổ/Tờ rời BHXH và Quyết định nghỉ việc của anh/chị đã được cơ quan BHXH gửi về văn phòng công ty. Anh/chị vui lòng phản hồi email này và cung cấp các thông tin bên dưới để HR sắp xếp gửi chuyển phát đến anh/chị.</p>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td style="padding:0 28px 16px 28px;">
                                            <table border="0" cellpadding="0" cellspacing="0" width="100%" bgcolor="#fff7e8" style="border-collapse:separate;border-spacing:0;background-color:#fff7e8;border:1px solid #f2d39a;border-radius:16px;">
                                                <tr>
                                                    <td style="padding:16px 18px;">
                                                        <div style="font-size:12px;font-weight:800;letter-spacing:0.4px;text-transform:uppercase;color:#8d5a00;margin-bottom:12px;">Thông tin cần phản hồi</div>
                                                        <table border="0" cellpadding="0" cellspacing="0" width="100%">
                                                            <tr>
                                                                <td style="padding:0 0 10px 0;font-size:13px;color:#6b625a;width:40%;">Địa chỉ nhận</td>
                                                                <td style="padding:0 0 10px 0;font-size:13px;color:#221f1c;font-weight:600;">................................................</td>
                                                            </tr>
                                                            <tr>
                                                                <td style="padding:0 0 10px 0;font-size:13px;color:#6b625a;">Họ tên người nhận</td>
                                                                <td style="padding:0 0 10px 0;font-size:13px;color:#221f1c;font-weight:600;">................................................</td>
                                                            </tr>
                                                            <tr>
                                                                <td style="padding:0;font-size:13px;color:#6b625a;">Số điện thoại người nhận</td>
                                                                <td style="padding:0;font-size:13px;color:#221f1c;font-weight:600;">................................................</td>
                                                            </tr>
                                                        </table>
                                                    </td>
                                                </tr>
                                            </table>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td style="padding:0 28px 16px 28px;">
                                            <div style="padding:16px 18px;background-color:#fff3f1;border-left:4px solid #da291c;border-radius:14px;">
                                                <p style="margin:0 0 10px 0;font-size:13px;line-height:1.7;color:#3d3833;">
                                                    <strong style="color:#b5121b;">Lưu ý:</strong> Từ ngày anh/chị phản hồi email, HR sẽ sắp xếp gửi hồ sơ trong khoảng <strong>4-5 ngày làm việc</strong>, không tính cuối tuần và ngày lễ.
                                                </p>
                                                <p style="margin:0;font-size:13px;line-height:1.7;color:#3d3833;">
                                                    Trường hợp phản hồi chậm trễ, ảnh hưởng đến việc hoàn thiện hồ sơ nhận Bảo hiểm thất nghiệp, công ty sẽ không chịu trách nhiệm.
                                                </p>
                                            </div>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td style="padding:0 28px 18px 28px;">
                                            <div style="padding:14px 16px;background-color:#f8f5ef;border-radius:14px;">
                                                <p style="margin:0;font-size:13px;line-height:1.7;color:#5a524b;">
                                                    <strong>Lưu ý thêm:</strong> Đối với anh/chị chuyển đổi loại hình <em>Full-time</em> sang <em>Part-time</em>, hồ sơ cũng sẽ được nhận theo thông tin như trên.
                                                </p>
                                            </div>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td style="padding:0 28px 26px 28px;">
                                            <p style="margin:0;font-size:14px;line-height:1.8;">Mong nhận được phản hồi sớm từ anh/chị.<br/><br/>Trân trọng,<br/><strong>Phòng Nhân sự</strong><br/>McDonald's Việt Nam</p>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td bgcolor="#f7f2e8" style="padding:14px 28px;background-color:#f7f2e8;border-top:1px solid #eadfce;">
                                            <p style="margin:0;font-size:12px;line-height:1.6;color:#7b7269;">Email này được gửi tự động từ quy trình offboarding RST. Vui lòng phản hồi trực tiếp email này để HR tiếp nhận thông tin gửi hồ sơ cho anh/chị.</p>
                                        </td>
                                    </tr>
                                </table>
                            </td>
                        </tr>
                    </table>
                </div>
            </field>
        </record>
    </data>
</odoo>

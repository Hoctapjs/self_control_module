<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
        <record id="email_template_manager_approval_reminder" model="mail.template">
            <field name="name">RST - Nhắc quản lý duyệt đơn nghỉ việc</field>
            <field name="model_id" ref="approvals.model_approval_request"/>
            <field name="subject">[RST Offboarding] Bạn có đơn nghỉ việc cần duyệt - {{ object.employee_id.name or object.request_owner_id.name }}</field>
            <field name="email_from">{{ (object.company_id.email or user.email) }}</field>
            <field name="body_html" type="html">
                <div style="margin:0;padding:24px 0;background-color:#f4f1ea;font-family:'Segoe UI',Arial,sans-serif;color:#2f2a26;">
                    <table border="0" cellpadding="0" cellspacing="0" width="100%" bgcolor="#f4f1ea" style="border-collapse:collapse;background-color:#f4f1ea;">
                        <tr>
                            <td align="center">
                                <table border="0" cellpadding="0" cellspacing="0" width="640" bgcolor="#fffdf9" style="width:640px;max-width:640px;background-color:#fffdf9;border:1px solid #eadfce;border-radius:18px;overflow:hidden;">
                                    <tr>
                                        <td bgcolor="#b5121b" style="padding:26px 32px;background-color:#b5121b;">
                                            <div style="font-size:12px;letter-spacing:1.2px;text-transform:uppercase;color:#ffe7a3;font-weight:700;margin-bottom:10px;">RST Approval</div>
                                            <h1 style="margin:0;font-size:26px;line-height:1.25;color:#ffffff;font-weight:800;">Bạn có đơn nghỉ việc cần duyệt</h1>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td style="padding:30px 32px 16px 32px;">
                                            <p style="margin:0 0 16px 0;font-size:15px;line-height:1.7;">Kính gửi Anh/Chị,</p>
                                            <p style="margin:0 0 18px 0;font-size:15px;line-height:1.7;">
                                                Hệ thống ghi nhận một đơn nghỉ việc RST đang chờ quản lý trực tiếp phê duyệt.
                                            </p>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td style="padding:0 32px 18px 32px;">
                                            <table border="0" cellpadding="0" cellspacing="0" width="100%" bgcolor="#fff7e8" style="border-collapse:separate;border-spacing:0;background-color:#fff7e8;border:1px solid #f2d39a;border-radius:16px;">
                                                <tr>
                                                    <td style="padding:18px 20px;">
                                                        <div style="font-size:13px;font-weight:800;letter-spacing:0.4px;text-transform:uppercase;color:#8d5a00;margin-bottom:14px;">Thông tin đơn</div>
                                                        <table border="0" cellpadding="0" cellspacing="0" width="100%">
                                                            <tr>
                                                                <td style="padding:0 0 10px 0;font-size:14px;color:#6b625a;width:34%;">Nhân viên</td>
                                                                <td style="padding:0 0 10px 0;font-size:14px;color:#221f1c;font-weight:700;"><t t-out="object.employee_id.name or object.request_owner_id.name"/></td>
                                                            </tr>
                                                            <tr>
                                                                <td style="padding:0 0 10px 0;font-size:14px;color:#6b625a;">Mã nhân viên</td>
                                                                <td style="padding:0 0 10px 0;font-size:14px;color:#221f1c;font-weight:600;"><t t-out="object.employee_id.barcode or 'N/A'"/></td>
                                                            </tr>
                                                            <tr>
                                                                <td style="padding:0;font-size:14px;color:#6b625a;">Ngày nghỉ dự kiến</td>
                                                                <td style="padding:0;font-size:14px;color:#221f1c;font-weight:600;"><t t-out="object.x_psm_0214_resignation_date or 'N/A'"/></td>
                                                            </tr>
                                                        </table>
                                                    </td>
                                                </tr>
                                            </table>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td align="center" style="padding:4px 32px 30px 32px;">
                                            <a t-att-href="object._get_0214_request_url()" style="display:inline-block;background-color:#b5121b;color:#ffffff;text-decoration:none;font-size:15px;font-weight:700;padding:12px 22px;border-radius:10px;">
                                                Mở đơn để duyệt
                                            </a>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td bgcolor="#f7f2e8" style="padding:16px 32px;background-color:#f7f2e8;border-top:1px solid #eadfce;">
                                            <p style="margin:0;font-size:12px;line-height:1.6;color:#7b7269;">Email này được gửi tự động từ quy trình offboarding RST.</p>
                                        </td>
                                    </tr>
                                </table>
                            </td>
                        </tr>
                    </table>
                </div>
            </field>
            <field name="auto_delete">True</field>
        </record>
    </data>
</odoo>

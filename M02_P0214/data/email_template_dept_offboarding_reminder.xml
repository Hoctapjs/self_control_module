<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
        <record id="email_template_dept_offboarding_reminder" model="mail.template">
            <field name="name">RST - Nhắc nhở công việc Offboarding (Bộ phận)</field>
            <field name="model_id" ref="approvals.model_approval_request"/>
            <field name="subject">[RST Offboarding] Bạn có công việc trễ hạn trong đơn nghỉ việc của {{ object.employee_id.name }}</field>
            <field name="email_from">{{ (user.email or user.company_id.email) }}</field>
            <field name="body_html" type="html">
                <div style="margin:0;padding:24px 0;background-color:#f4f1ea;font-family:'Segoe UI',Arial,sans-serif;color:#2f2a26;">
                    <table border="0" cellpadding="0" cellspacing="0" width="100%" bgcolor="#f4f1ea" style="border-collapse:collapse;background-color:#f4f1ea;">
                        <tr>
                            <td align="center">
                                <table border="0" cellpadding="0" cellspacing="0" width="640" bgcolor="#fffdf9" style="width:640px;max-width:640px;background-color:#fffdf9;border:1px solid #eadfce;border-radius:20px;overflow:hidden;">
                                    <tr>
                                        <td bgcolor="#b5121b" style="padding:0;background-color:#b5121b;">
                                            <table border="0" cellpadding="0" cellspacing="0" width="100%" bgcolor="#b5121b" style="background-color:#b5121b;">
                                                <tr>
                                                    <td style="padding:28px 32px 22px 32px;">
                                                        <div style="font-size:12px;letter-spacing:1.2px;text-transform:uppercase;color:#ffe7a3;font-weight:700;margin-bottom:10px;">RST Reminder</div>
                                                        <h1 style="margin:0;font-size:28px;line-height:1.25;color:#ffffff;font-weight:800;">Nhắc nhở công việc offboarding</h1>
                                                        <p style="margin:10px 0 0 0;font-size:14px;line-height:1.6;color:#fff4da;">Bạn đang có đầu việc trong quy trình nghỉ việc cần được xử lý sớm để đảm bảo bàn giao diễn ra đúng tiến độ.</p>
                                                    </td>
                                                </tr>
                                            </table>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td style="padding:30px 32px 12px 32px;">
                                            <p style="margin:0 0 16px 0;font-size:15px;line-height:1.7;">Chào bạn,</p>
                                            <p style="margin:0 0 18px 0;font-size:15px;line-height:1.7;">Bạn đang có nhiệm vụ trong quy trình nghỉ việc của nhân viên <strong><t t-out="object.employee_id.name"/></strong> (Mã NV: <t t-out="object.employee_id.barcode or 'N/A'"/>) hiện đang bị trễ hạn xử lý.</p>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td style="padding:0 32px 18px 32px;">
                                            <table border="0" cellpadding="0" cellspacing="0" width="100%" bgcolor="#fff7e8" style="border-collapse:separate;border-spacing:0;background-color:#fff7e8;border:1px solid #f2d39a;border-radius:16px;">
                                                <tr>
                                                    <td style="padding:18px 20px;">
                                                        <div style="font-size:13px;font-weight:800;letter-spacing:0.4px;text-transform:uppercase;color:#8d5a00;margin-bottom:14px;">Thông tin liên quan</div>
                                                        <table border="0" cellpadding="0" cellspacing="0" width="100%">
                                                            <tr>
                                                                <td style="padding:0 0 10px 0;font-size:14px;color:#6b625a;width:34%;">Nhân viên</td>
                                                                <td style="padding:0 0 10px 0;font-size:14px;color:#221f1c;font-weight:700;"><t t-out="object.employee_id.name"/></td>
                                                            </tr>
                                                            <tr>
                                                                <td style="padding:0;font-size:14px;color:#6b625a;">Mã nhân viên</td>
                                                                <td style="padding:0;font-size:14px;color:#221f1c;font-weight:600;"><t t-out="object.employee_id.barcode or 'N/A'"/></td>
                                                            </tr>
                                                        </table>
                                                    </td>
                                                </tr>
                                            </table>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td style="padding:0 32px 18px 32px;">
                                            <div style="padding:18px 20px;background-color:#fff3f1;border-left:4px solid #da291c;border-radius:14px;">
                                                <p style="margin:0 0 10px 0;font-size:14px;line-height:1.7;color:#3d3833;">
                                                    <strong style="color:#b5121b;">Cần xử lý:</strong> Vui lòng rà soát và hoàn tất các hạng mục do bạn phụ trách trên hệ thống Odoo.
                                                </p>
                                                <p style="margin:0;font-size:14px;line-height:1.7;color:#3d3833;">
                                                    Hệ thống đã tự động gia hạn thêm 4 ngày để bạn có thêm thời gian hoàn thành công việc.
                                                </p>
                                            </div>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td style="padding:0 32px 30px 32px;">
                                            <p style="margin:0;font-size:15px;line-height:1.8;">Rất mong bạn sớm hoàn thành để quy trình nghỉ việc được suôn sẻ.<br/><br/>Trân trọng,<br/><strong>Phòng Nhân sự</strong></p>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td bgcolor="#f7f2e8" style="padding:16px 32px;background-color:#f7f2e8;border-top:1px solid #eadfce;">
                                            <p style="margin:0;font-size:12px;line-height:1.6;color:#7b7269;">Email này được gửi tự động từ quy trình offboarding RST. Vui lòng không trả lời nếu không cần thiết.</p>
                                        </td>
                                    </tr>
                                </table>
                            </td>
                        </tr>
                    </table>
                </div>
            </field>
        </record>
    </data>
</odoo>

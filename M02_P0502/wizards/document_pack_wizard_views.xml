<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_psm_0502_document_pack_wizard_form" model="ir.ui.view">
        <field name="name">psm.0502.document.pack.wizard.form</field>
        <field name="model">x_psm_0502_document_pack_wizard</field>
        <field name="arch" type="xml">
            <form string="Print 0502 Document Pack">
                <group>
                    <field name="x_psm_request_id"/>
                </group>
                <group string="Documents">
                    <field name="x_psm_include_request_document"/>
                    <field name="x_psm_include_inspection_report"/>
                    <field name="x_psm_include_treatment_proposal"/>
                    <field name="x_psm_include_material_issue_request"/>
                    <field name="x_psm_include_acceptance_record"/>
                </group>
                <footer>
                    <button
                        name="action_psm_print_document_pack"
                        string="Print"
                        type="object"
                        class="btn-primary"
                    />
                    <button string="Cancel" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ke thua form view cua stock picking de nhin thay request 0502 nguon -->
    <record id="view_psm_stock_picking_form" model="ir.ui.view">
        <field name="name">psm.stock.picking.form</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form"/>
        <field name="arch" type="xml">
            <!-- chen lien ket request 0502 va fsm task sau origin de doi kho nhin thay nguon phat sinh -->
            <xpath expr="//field[@name='origin']" position="after">
                <field name="x_psm_0502_request_id" readonly="1"/>
                <field name="x_psm_0502_fsm_task_id" readonly="1"/>
            </xpath>
        </field>
    </record>

    <!-- ke thua list view cua stock picking de bo sung request 0502 -->
    <record id="view_psm_stock_picking_list" model="ir.ui.view">
        <field name="name">psm.stock.picking.list</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.vpicktree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='origin']" position="after">
                <field name="x_psm_0502_request_id" optional="hide"/>
                <field name="x_psm_0502_fsm_task_id" optional="hide"/>
            </xpath>
        </field>
    </record>
</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="hr_contract_kind_view_form" model="ir.ui.view">
        <field name="name">hr.contract.kind.view.form</field>
        <field name="model">hr.contract.kind</field>
        <field name="arch" type="xml">
            <form string="Contract Kind">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="code"/>
                            <field name="contract_type_id"/>
                        </group>
                        <group>
                            <field name="kind_type"/>
                            <label for="duration"/>
                            <div class="o_row">
                                <field name="duration" class="oe_inline"/>
                                <field name="duration_unit" class="oe_inline"/>
                            </div>
                        </group>
                    </group>
                    <notebook>
                        <page string="Description" name="description">
                            <field name="description" placeholder="Mô tả chi tiết loại hợp đồng..."/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="hr_contract_kind_view_tree" model="ir.ui.view">
        <field name="name">hr.contract.kind.view.list</field>
        <field name="model">hr.contract.kind</field>
        <field name="arch" type="xml">
            <list string="Contract Kinds">
                <field name="name"/>
                <field name="code"/>
                <field name="kind_type"/>
                <field name="duration"/>
                <field name="duration_unit"/>
                <field name="contract_type_id"/>
            </list>
        </field>
    </record>

    <record id="hr_contract_kind_action" model="ir.actions.act_window">
        <field name="name">Contract Kinds</field>
        <field name="res_model">hr.contract.kind</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_hr_contract_kind"
              name="Contract Kinds"
              parent="hr.menu_human_resources_configuration"
              action="hr_contract_kind_action"
              sequence="25"/>
</odoo>

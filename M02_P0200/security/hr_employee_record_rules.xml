<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Record Rules: hr.employee | Từ: P0200, P0209 -->

    <!-- [P0200] PM / Recruitment User / Internal User: own department -->
    <record id="rule_hr_employee_pm_own_dept" model="ir.rule">
        <field name="name">Employee: PM sees own department</field>
        <field name="model_id" ref="hr.model_hr_employee"/>
        <field name="domain_force">
            ['|', ('department_id', '=', False),
                  ('department_id', 'child_of', user.employee_id.department_id.id)]
        </field>
        <field name="groups" eval="[
            (4, ref('GDH_OPS_STORE_PM_M')),
            (4, ref('hr_recruitment.group_hr_recruitment_user')),
            (4, ref('base.group_user'))
        ]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <!-- [P0200] HR Staff: see ALL employees -->
    <record id="rule_hr_employee_hr_staff_all" model="ir.rule">
        <field name="name">Employee: HR Staff sees all</field>
        <field name="model_id" ref="hr.model_hr_employee"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[
            (4, ref('GDH_RST_HR_RECRUITMENT_S')),
            (4, ref('GDH_RST_HR_CNB_S')),
            (4, ref('GDH_RST_HR_HRBP_S')),
            (4, ref('GDH_RST_HR_ADMIN_S'))
        ]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <!-- [P0209] RGM: read/write own department employees (L&D context) -->
    <record id="hr_employee_rgm_rule" model="ir.rule">
        <field name="name">Store L&amp;D: RGM view own department Employees</field>
        <field name="model_id" ref="hr.model_hr_employee"/>
        <field name="groups" eval="[(4, ref('GDH_OPS_STORE_RGM_M'))]"/>
        <field name="domain_force">[
            ('company_id', 'in', user.company_ids.ids + [False]),
            ('department_id', 'child_of', user.employee_ids.mapped('department_id').ids)]</field>
        <field name="perm_read" eval="1"/>
        <field name="perm_write" eval="1"/>
        <field name="perm_create" eval="0"/>
        <field name="perm_unlink" eval="0"/>
    </record>




    <!-- L&D: View/Write all Employees 0209 -->
        <record id="hr_employee_ld_rule" model="ir.rule">
            <field name="name">L&amp;D can see and edit all Employees</field>
            <field name="model_id" ref="hr.model_hr_employee" />
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('M02_P0200.GDH_RST_LND_LD_S')), (4, ref('M02_P0200.GDH_RST_LND_MANAGER_M'))]" />
            <field name="perm_read" eval="1" />
            <field name="perm_write" eval="1" />
            <field name="perm_create" eval="0" />
            <field name="perm_unlink" eval="0" />
        </record>
</odoo>

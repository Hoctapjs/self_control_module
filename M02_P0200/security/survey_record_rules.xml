<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Record Rules: survey.survey, survey.question, survey.user_input | Từ: P0209, P0213, P0214 -->

    <!-- [P0209] BASE: full access all surveys -->
    <record id="x_psm_survey_base_rule" model="ir.rule">
        <field name="name">Survey: Odoo Base view all surveys</field>
        <field name="model_id" ref="survey.model_survey_survey"/>
        <field name="groups" eval="[(4, ref('GDH_RST_ALL_BASE_S'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="perm_read" eval="1"/>
        <field name="perm_write" eval="1"/>
        <field name="perm_create" eval="1"/>
        <field name="perm_unlink" eval="1"/>
    </record>

    <!-- [P0209] BASE: full access all questions -->
    <record id="x_psm_survey_question_base_rule" model="ir.rule">
        <field name="name">Survey: Odoo Base view all survey questions</field>
        <field name="model_id" ref="survey.model_survey_question"/>
        <field name="groups" eval="[(4, ref('GDH_RST_ALL_BASE_S'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="perm_read" eval="1"/>
        <field name="perm_write" eval="1"/>
        <field name="perm_create" eval="1"/>
        <field name="perm_unlink" eval="1"/>
    </record>

    <!-- [P0213] Portal: own survey inputs -->
    <record id="rule_psm_0213_survey_user_input_portal_own" model="ir.rule">
        <field name="name">0213 portal chi xem survey.user_input cua chinh minh</field>
        <field name="model_id" ref="survey.model_survey_user_input"/>
        <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
        <field name="domain_force">['|', ('partner_id', '=', user.partner_id.id), ('email', '=', user.email)]</field>
    </record>

    <!-- [P0214] Portal: own survey inputs -->
    <record id="rule_psm_0214_survey_user_input_portal_own" model="ir.rule">
        <field name="name">0214 portal chi xem survey.user_input cua chinh minh</field>
        <field name="model_id" ref="survey.model_survey_user_input"/>
        <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
        <field name="domain_force">['|', ('partner_id', '=', user.partner_id.id), ('email', '=', user.email)]</field>
    </record>


<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Define a shared category for all organization groups -->
    <record id="module_category_gdh_organization" model="ir.module.category">
        <field name="name">GDH Organization Groups</field>
        <field name="description">Organization-wide groups for role-based access control.</field>
        <field name="sequence">100</field>
    </record>

    <!-- Odoo 19 mandatory: Define a Privilege to link groups to Category -->
    <record id="res_groups_privilege_gdh" model="res.groups.privilege">
        <field name="name">GDH System Access</field>
        <field name="category_id" ref="module_category_gdh_organization" />
        <field name="sequence">10</field>
    </record>

    <!-- Base User Group (S) -->
    <record id="GDH_RST_ALL_BASE_S" model="res.groups">
        <field name="name">BASE - Người dùng hệ thống (Odoo Base)</field>
        <field name="privilege_id" ref="res_groups_privilege_gdh" />
        <!-- Implies base.group_user to give access to standard Odoo features -->
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]" />
    </record>

    <!-- Store / OPS Groups -->
    <record id="GDH_OPS_STORE_CREW_S" model="res.groups">
        <field name="name">OPS - Crew</field>
        <field name="privilege_id" ref="res_groups_privilege_gdh" />
    </record>

    <record id="GDH_OPS_STORE_TRAINER_S" model="res.groups">
        <field name="name">OPS - Crew trainer</field>
        <field name="privilege_id" ref="res_groups_privilege_gdh" />
    </record>

    <record id="GDH_OPS_STORE_GEL_M" model="res.groups">
        <field name="name">OPS - GEL</field>
        <field name="privilege_id" ref="res_groups_privilege_gdh" />
    </record>

    <record id="GDH_OPS_STORE_SM_M" model="res.groups">
        <field name="name">OPS - Shift manager</field>
        <field name="privilege_id" ref="res_groups_privilege_gdh" />
    </record>

    <record id="GDH_OPS_STORE_ST_M" model="res.groups">
        <field name="name">OPS - System manager</field>
        <field name="privilege_id" ref="res_groups_privilege_gdh" />
    </record>

    <record id="GDH_OPS_STORE_PM_M" model="res.groups">
        <field name="name">OPS - People manager</field>
        <field name="privilege_id" ref="res_groups_privilege_gdh" />
        <field name="implied_ids"
            eval="[(4, ref('hr_recruitment.group_hr_recruitment_interviewer'))]" />
    </record>

    <record id="GDH_OPS_STORE_RGM_M" model="res.groups">
        <field name="name">OPS - Cửa hàng trưởng</field>
        <field name="privilege_id" ref="res_groups_privilege_gdh" />
        <field name="implied_ids"
            eval="[
            (4, ref('GDH_OPS_STORE_CREW_S')), 
            (4, ref('GDH_OPS_STORE_TRAINER_S')), 
            (4, ref('GDH_OPS_STORE_GEL_M')), 
            (4, ref('GDH_OPS_STORE_SM_M')), 
            (4, ref('GDH_OPS_STORE_ST_M')), 
            (4, ref('GDH_OPS_STORE_PM_M'))
        ]" />
    </record>

    <!-- OPS Consultant -->
    <record id="GDH_RST_OPS_OC_S" model="res.groups">
        <field name="name">OPS - Operation consultant</field>
        <field name="privilege_id" ref="res_groups_privilege_gdh" />
    </record>

    <record id="GDH_RST_OPS_OM_M" model="res.groups">
        <field name="name">OPS - Operation consultant manager</field>
        <field name="privilege_id" ref="res_groups_privilege_gdh" />
        <field name="implied_ids" eval="[(4, ref('GDH_RST_OPS_OC_S'))]" />
    </record>

    <!-- Staff HR Groups (S) -->
    <record id="GDH_RST_HR_RECRUITMENT_S" model="res.groups">
        <field name="name">RST - Nhân viên tuyển dụng</field>
        <field name="privilege_id" ref="res_groups_privilege_gdh" />
        <field name="implied_ids"
            eval="[(4, ref('GDH_OPS_STORE_PM_M')), (4, ref('GDH_RST_ALL_BASE_S')), (4, ref('hr_recruitment.group_hr_recruitment_user'))]" />
    </record>

    <record id="GDH_RST_HR_CNB_S" model="res.groups">
        <field name="name">RST - Nhân viên tính lương</field>
        <field name="privilege_id" ref="res_groups_privilege_gdh" />
        <field name="implied_ids"
            eval="[(4, ref('GDH_OPS_STORE_PM_M')), (4, ref('GDH_RST_ALL_BASE_S')), (4, ref('hr_payroll.group_hr_payroll_user'))]" />
    </record>

    <record id="GDH_RST_HR_HRBP_S" model="res.groups">
        <field name="name">RST - Nhân viên HRBP</field>
        <field name="privilege_id" ref="res_groups_privilege_gdh" />
        <field name="implied_ids"
            eval="[(4, ref('GDH_OPS_STORE_PM_M')), (4, ref('GDH_RST_ALL_BASE_S')), (4, ref('hr_recruitment.group_hr_recruitment_user'))]" />
    </record>

    <record id="GDH_RST_HR_ADMIN_S" model="res.groups">
        <field name="name">RST - Nhân viên admin</field>
        <field name="privilege_id" ref="res_groups_privilege_gdh" />
        <field name="implied_ids"
            eval="[(4, ref('GDH_OPS_STORE_PM_M')), (4, ref('GDH_RST_ALL_BASE_S'))]" />
    </record>

    <!-- Manager Groups (M) -->
    <record id="GDH_RST_HR_RECRUITMENT_M" model="res.groups">
        <field name="name">RST - Quản lý tuyển dụng</field>
        <field name="privilege_id" ref="res_groups_privilege_gdh" />
        <field name="implied_ids" eval="[(4, ref('GDH_RST_HR_RECRUITMENT_S'))]" />
    </record>

    <record id="GDH_RST_HR_CNB_M" model="res.groups">
        <field name="name">RST - Quản lý tính lương</field>
        <field name="privilege_id" ref="res_groups_privilege_gdh" />
        <field name="implied_ids" eval="[(4, ref('GDH_RST_HR_CNB_S'))]" />
    </record>

    <record id="GDH_RST_HR_HRBP_M" model="res.groups">
        <field name="name">RST - Quản lý HRBP</field>
        <field name="privilege_id" ref="res_groups_privilege_gdh" />
        <field name="implied_ids"
            eval="[(4, ref('GDH_RST_HR_HRBP_S')), (4, ref('GDH_RST_HR_ADMIN_S'))]" />
    </record>

    <record id="GDH_RST_HR_ADMIN_M" model="res.groups">
        <field name="name">RST - Quản lý admin</field>
        <field name="privilege_id" ref="res_groups_privilege_gdh" />
        <field name="implied_ids"
            eval="[(4, ref('GDH_RST_HR_ADMIN_S')), (4, ref('GDH_RST_ALL_BASE_S'))]" />
    </record>

    <!-- HR Head (M) -->
    <record id="GDH_RST_HR_HEAD_M" model="res.groups">
        <field name="name">RST - Trưởng phòng nhân sự</field>
        <field name="privilege_id" ref="res_groups_privilege_gdh" />
        <field name="implied_ids"
            eval="[
            (4, ref('GDH_RST_HR_RECRUITMENT_M')), 
            (4, ref('GDH_RST_HR_CNB_M')), 
            (4, ref('GDH_RST_HR_ADMIN_M')), 
            (4, ref('GDH_RST_HR_HRBP_M')),
            (4, ref('GDH_OPS_STORE_RGM_M')), 
            (4, ref('GDH_RST_OPS_OM_M'))
        ]" />
    </record>

    <!-- L&D Groups -->
    <record id="GDH_RST_LND_LD_S" model="res.groups">
        <field name="name">RST - Nhân viên L&amp;D</field>
        <field name="privilege_id" ref="res_groups_privilege_gdh" />
        <field name="implied_ids" eval="[(4, ref('GDH_RST_ALL_BASE_S'))]" />
    </record>

    <record id="GDH_RST_LND_MANAGER_M" model="res.groups">
        <field name="name">RST - Quản lý L&amp;D</field>
        <field name="privilege_id" ref="res_groups_privilege_gdh" />
        <field name="implied_ids" eval="[(4, ref('GDH_RST_LND_LD_S'))]" />
    </record>

    <!-- IT Groups -->
    <record id="GDH_RST_IT_STL_S" model="res.groups">
        <field name="name">RST - Support team Leader</field>
        <field name="privilege_id" ref="res_groups_privilege_gdh" />
        <field name="implied_ids" eval="[(4, ref('GDH_RST_ALL_BASE_S'))]" />
    </record>

    <record id="GDH_RST_IT_DE_S" model="res.groups">
        <field name="name">RST - Data Engineer</field>
        <field name="privilege_id" ref="res_groups_privilege_gdh" />
        <field name="implied_ids" eval="[(4, ref('GDH_RST_ALL_BASE_S'))]" />
    </record>

    <record id="GDH_RST_IT_NE_S" model="res.groups">
        <field name="name">RST - Network Engineer</field>
        <field name="privilege_id" ref="res_groups_privilege_gdh" />
        <field name="implied_ids" eval="[(4, ref('GDH_RST_ALL_BASE_S'))]" />
    </record>

    <record id="GDH_RST_IT_ITD_S" model="res.groups">
        <field name="name">RST - IT Deployment Coordinator</field>
        <field name="privilege_id" ref="res_groups_privilege_gdh" />
        <field name="implied_ids" eval="[(4, ref('GDH_RST_ALL_BASE_S'))]" />
    </record>

    <record id="GDH_RST_IT_HEAD_M" model="res.groups">
        <field name="name">RST - Quản lý IT</field>
        <field name="privilege_id" ref="res_groups_privilege_gdh" />
        <field name="implied_ids"
            eval="[
            (4, ref('GDH_RST_IT_STL_S')),
            (4, ref('GDH_RST_IT_DE_S')),
            (4, ref('GDH_RST_IT_NE_S')),
            (4, ref('GDH_RST_IT_ITD_S'))
        ]" />
    </record>

    <!-- High Level Management -->
    <record id="GDH_RST_MGMT_MANAGER_M" model="res.groups">
        <field name="name">RST - C-Level / Ban quản lý cấp cao</field>
        <field name="privilege_id" ref="res_groups_privilege_gdh" />
        <field name="implied_ids" eval="[(4, ref('GDH_RST_ALL_BASE_S'))]" />
    </record>


    <!-- ROOT SYSTEM MANAGER (M) -->
    <record id="GDH_RST_SYSTEM_ST_M" model="res.groups">
        <field name="name">RST - Quản lý hệ thống</field>
        <field name="privilege_id" ref="res_groups_privilege_gdh" />
        <field name="implied_ids"
            eval="[
            (4, ref('GDH_RST_ALL_BASE_S')), 
            (4, ref('GDH_RST_HR_HEAD_M')),
            (4, ref('GDH_RST_LND_MANAGER_M')),
            (4, ref('GDH_RST_IT_HEAD_M')),
            (4, ref('GDH_RST_MGMT_MANAGER_M'))
        ]" />
    </record>


</odoo>
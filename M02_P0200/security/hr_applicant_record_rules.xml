<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Record Rules: hr.applicant | Từ: P0200 -->

    <!-- [P0200] PM + Recruitment User: own dept -->
    <record id="rule_hr_applicant_pm_own_dept" model="ir.rule">
        <field name="name">Applicant: PM sees own department</field>
        <field name="model_id" ref="hr_recruitment.model_hr_applicant"/>
        <field name="domain_force">['|', ('department_id', '=', False), ('department_id', 'child_of', user.employee_id.department_id.id)]</field>
        <field name="groups" eval="[(4, ref('GDH_OPS_STORE_PM_M')), (4, ref('hr_recruitment.group_hr_recruitment_user'))]"/>
    </record>

    <!-- [P0200] HR Staff: all -->
    <record id="rule_hr_applicant_hr_staff_all" model="ir.rule">
        <field name="name">Applicant: HR Staff sees all</field>
        <field name="model_id" ref="hr_recruitment.model_hr_applicant"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('GDH_RST_HR_RECRUITMENT_S')), (4, ref('GDH_RST_HR_CNB_S')), (4, ref('GDH_RST_HR_HRBP_S')), (4, ref('GDH_RST_HR_ADMIN_S'))]"/>
    </record>


    <!-- Keep only 0200 HR manager as backend authority in 0204 (store scope by department). -->

    <!-- Re-enable upstream multi-company applicant rule if an older 0204 version disabled it. -->
    <record id="hr_recruitment.hr_applicant_comp_rule" model="ir.rule">
        <field name="active" eval="True"/>
    </record>
    <record id="hr_applicant_comp_rule_custom" model="ir.rule">
        <field name="name">Applicant multi company rule (Custom - Disabled)</field>
        <field name="model_id" ref="hr_recruitment.model_hr_applicant"/>
        <field name="global" eval="True"/>
        <field name="active" eval="False"/>
        <field name="domain_force">['|', ('company_id', 'in', company_ids), ('company_id', '=', False)]</field>
    </record>
    <!-- Store Applicant: recruitment staff scope by own department. -->
    <record id="rule_hr_applicant_department_hierarchy" model="ir.rule">
        <field name="name">HR Applicant: Store HR by Department</field>
        <field name="model_id" ref="hr_recruitment.model_hr_applicant"/>
        <field name="groups" eval="[(6, 0, [ref('M02_P0200.GDH_RST_HR_RECRUITMENT_S')])]"/>
        <field name="active" eval="True"/>
        <field name="domain_force">[('department_id', 'in', user.employee_ids.mapped('department_id').ids)]</field>
        <field name="perm_read">1</field>
        <field name="perm_write">1</field>
        <field name="perm_create">1</field>
        <field name="perm_unlink">0</field>
    </record>
    <record id="rule_hr_applicant_user_all" model="ir.rule">
        <field name="name">Legacy HR Applicant User Rule (Disabled)</field>
        <field name="model_id" ref="hr_recruitment.model_hr_applicant"/>
        <field name="groups" eval="[(6, 0, [ref('M02_P0200.GDH_RST_HR_RECRUITMENT_M')])]"/>
        <field name="active" eval="False"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="perm_read">1</field>
        <field name="perm_write">1</field>
        <field name="perm_create">1</field>
        <field name="perm_unlink">1</field>
    </record>
    <record id="rule_hr_applicant_interviewer" model="ir.rule">
        <field name="name">Legacy Interviewer Applicant Rule (Disabled)</field>
        <field name="model_id" ref="hr_recruitment.model_hr_applicant"/>
        <field name="groups" eval="[(6, 0, [ref('M02_P0200.GDH_RST_HR_RECRUITMENT_M')])]"/>
        <field name="active" eval="False"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="perm_read">1</field>
        <field name="perm_write">0</field>
        <field name="perm_create">0</field>
        <field name="perm_unlink">0</field>
    </record>
    <!-- RGM: Applicant — read-only, store type, own department only. -->
    <record id="rule_hr_applicant_rgm_department" model="ir.rule">
        <field name="name">HR Applicant: RGM read-only by Department</field>
        <field name="model_id" ref="hr_recruitment.model_hr_applicant"/>
        <field name="groups" eval="[(6, 0, [ref('M02_P0200.GDH_OPS_STORE_RGM_M')])]"/>
        <field name="domain_force">[('department_id', 'in', user.employee_ids.mapped('department_id').ids)]</field>
        <field name="perm_read">1</field>
        <field name="perm_write">0</field>
        <field name="perm_create">0</field>
        <field name="perm_unlink">0</field>
    </record>
</odoo>

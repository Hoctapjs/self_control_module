<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Record Rules: slide.channel + slide.slide | Từ: P0209 -->

    <!-- [P0209] BASE: full access all courses -->
    <record id="x_psm_slide_channel_base_rule" model="ir.rule">
        <field name="name">eLearning: Odoo Base view all courses</field>
        <field name="model_id" ref="website_slides.model_slide_channel"/>
        <field name="groups" eval="[(4, ref('GDH_RST_ALL_BASE_S'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="perm_read" eval="1"/>
        <field name="perm_write" eval="1"/>
        <field name="perm_create" eval="1"/>
        <field name="perm_unlink" eval="1"/>
    </record>

    <!-- [P0209] BASE: full access all slides -->
    <record id="x_psm_slide_slide_base_rule" model="ir.rule">
        <field name="name">eLearning: Odoo Base view all slides</field>
        <field name="model_id" ref="website_slides.model_slide_slide"/>
        <field name="groups" eval="[(4, ref('GDH_RST_ALL_BASE_S'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="perm_read" eval="1"/>
        <field name="perm_write" eval="1"/>
        <field name="perm_create" eval="1"/>
        <field name="perm_unlink" eval="1"/>
    </record>



      "fields": {
        "name": "PSM Discipline Record Portal Own",
        "model_id": {
          "ref": "model_x_psm_hr_discipline_record"
        },
        "domain_force": "[\n                '|',\n                ('x_psm_employee_id.user_id', '=', user.id),\n                ('x_psm_employee_id.work_email', 'in', [user.login, user.email])\n                ]",

<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
        <!-- Discipline Record Rules -->
        <record id="rule_psm_hr_discipline_record_portal_own" model="ir.rule">
            <field name="name">PSM Discipline Record Portal Own</field>
            <field name="model_id" ref="M02_P0215.model_x_psm_hr_discipline_record"/>
            <field name="domain_force">[
                '|',
                ('x_psm_employee_id.user_id', '=', user.id),
                ('x_psm_employee_id.work_email', 'in', [user.login, user.email])
                ]</field>
            <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <record id="rule_psm_hr_discipline_record_store_manager" model="ir.rule">

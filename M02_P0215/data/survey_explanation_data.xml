<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="survey_psm_explanation" model="survey.survey">
            <field name="title">0215 - Tường trình nhân viên</field>
            <field name="user_id" ref="base.user_admin"/>
            <field name="access_mode">public</field>
            <field name="users_login_required" eval="True"/>
            <field name="users_can_go_back" eval="True"/>
            <field name="questions_layout">page_per_section</field>
            <field name="lang_ids" eval="False"/>
            <field name="description" type="html">
                <p>Biểu mẫu tường trình dành cho nhân viên trong quy trình 0215.</p>
            </field>
            <field name="description_done" type="html">
                <p>Tường trình đã được ghi nhận.</p>
            </field>
        </record>

        <record id="survey_psm_explanation_page_main" model="survey.question">
            <field name="title">Thông tin tường trình</field>
            <field name="survey_id" ref="survey_psm_explanation"/>
            <field name="sequence">1</field>
            <field name="question_type" eval="False"/>
            <field name="is_page" eval="True"/>
        </record>

        <record id="survey_psm_explanation_question_incident_datetime" model="survey.question">
            <field name="survey_id" ref="survey_psm_explanation"/>
            <field name="sequence">2</field>
            <field name="title">Thời gian xảy ra sự việc</field>
            <field name="question_type">datetime</field>
            <field name="constr_mandatory" eval="True"/>
        </record>

        <record id="survey_psm_explanation_question_incident_location" model="survey.question">
            <field name="survey_id" ref="survey_psm_explanation"/>
            <field name="sequence">3</field>
            <field name="title">Địa điểm xảy ra sự việc</field>
            <field name="question_type">char_box</field>
            <field name="question_placeholder">Ví dụ: Khu bếp, quầy thu ngân...</field>
            <field name="constr_mandatory" eval="True"/>
        </record>

        <record id="survey_psm_explanation_question_witness_names" model="survey.question">
            <field name="survey_id" ref="survey_psm_explanation"/>
            <field name="sequence">4</field>
            <field name="title">Người chứng kiến</field>
            <field name="question_type">char_box</field>
            <field name="question_placeholder">Nhập tên người chứng kiến nếu có</field>
            <field name="constr_mandatory" eval="False"/>
        </record>

        <record id="survey_psm_explanation_question_content" model="survey.question">
            <field name="survey_id" ref="survey_psm_explanation"/>
            <field name="sequence">5</field>
            <field name="title">Nội dung tường trình</field>
            <field name="question_type">text_box</field>
            <field name="constr_mandatory" eval="True"/>
        </record>

        <record id="survey_psm_explanation_question_reason" model="survey.question">
            <field name="survey_id" ref="survey_psm_explanation"/>
            <field name="sequence">6</field>
            <field name="title">Nguyên nhân</field>
            <field name="question_type">text_box</field>
            <field name="constr_mandatory" eval="True"/>
        </record>

        <record id="survey_psm_explanation_question_commitment" model="survey.question">
            <field name="survey_id" ref="survey_psm_explanation"/>
            <field name="sequence">7</field>
            <field name="title">Cam kết cải thiện</field>
            <field name="question_type">text_box</field>
            <field name="constr_mandatory" eval="True"/>
        </record>

        <record id="survey_psm_explanation_question_confirmation" model="survey.question">
            <field name="survey_id" ref="survey_psm_explanation"/>
            <field name="sequence">8</field>
            <field name="title">Xác nhận</field>
            <field name="question_type">simple_choice</field>
            <field name="constr_mandatory" eval="True"/>
        </record>

        <record id="survey_psm_explanation_question_confirmation_answer_yes" model="survey.question.answer">
            <field name="question_id" ref="survey_psm_explanation_question_confirmation"/>
            <field name="sequence">1</field>
            <field name="value">Tôi xác nhận nội dung tường trình là đúng và đầy đủ.</field>
        </record>
    </data>
</odoo>

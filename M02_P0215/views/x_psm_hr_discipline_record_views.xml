<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Sequence -->
    <record id="seq_psm_hr_discipline_record" model="ir.sequence">
        <field name="name">Discipline Record Sequence</field>
        <field name="code">x_psm.hr.discipline.record</field>
        <field name="prefix">DIS/%(year)s/</field>
        <field name="padding">4</field>
        <field name="company_id" eval="False" />
    </record>

    <!-- Tree View -->
    <record id="view_psm_hr_discipline_record_tree" model="ir.ui.view">
        <field name="name">hr.discipline.record.tree</field>
        <field name="model">x_psm.hr.discipline.record</field>
        <field name="arch" type="xml">
            <list string="Disciplinary Records" decoration-danger="state == 'approval'"
                decoration-muted="state == 'cancel'">
                <field name="name" />
                <field name="x_psm_date" />
                <field name="x_psm_employee_id" />
                <field name="x_psm_violation_category_id" />
                <field name="x_psm_violation_type" />
                <field name="x_psm_action_id" />
                <field name="state" widget="badge" decoration-info="state == 'draft'"
                    decoration-success="state == 'active'" decoration-warning="state == 'expired'" />
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_psm_hr_discipline_record_form" model="ir.ui.view">
        <field name="name">hr.discipline.record.form</field>
        <field name="model">x_psm.hr.discipline.record</field>
        <field name="arch" type="xml">
            <form string="Disciplinary Record">
                <header>
                    <!-- Bước 1: Draft -->
                    <button name="action_psm_send_to_employee" string="Gửi yêu cầu tường trình"
                        type="object" class="btn-secondary" invisible="state != 'draft'" />
                    <button name="action_psm_confirm" string="Gửi RGM Xem xét" type="object"
                        class="oe_highlight" invisible="state != 'draft'" />
                    <button name="action_psm_reject_explanation" string="Từ chối / Yêu cầu lại"
                        type="object" class="btn-secondary" invisible="state != 'draft'" />

                    <!-- Bước 2: Under Review - RGM Kiểm tra Tái phạm -->
                    <button name="action_psm_rgm_no_repeat" string="Xác định hình thức"
                        type="object" class="btn-success"
                        invisible="state != 'under_review' or x_psm_rgm_is_repeat"
                        groups="M02_P0200.GDH_OPS_STORE_RGM_M" />
                    <button name="action_psm_rgm_repeat" string="Có tái phạm" type="object"
                        class="btn-danger"
                        invisible="state != 'under_review' or x_psm_rgm_is_repeat"
                        groups="M02_P0200.GDH_OPS_STORE_RGM_M" />

                    <!-- Bước 3: Level Determination -->
                    <button name="action_psm_rgm_store_level" string="Store Level" type="object"
                        class="oe_highlight" invisible="state != 'level_determination'"
                        groups="M02_P0200.GDH_OPS_STORE_RGM_M" />
                    <button name="action_psm_rgm_company_level" string="Company Level" type="object"
                        class="btn-danger" invisible="state != 'level_determination'"
                        groups="M02_P0200.GDH_OPS_STORE_RGM_M" />

                    <!-- Bước 4: Investigation -->
                    <button name="action_psm_schedule_hearing" string="Cần họp kỷ luật"
                        type="object" class="btn-primary" invisible="state != 'investigation'"
                        groups="M02_P0200.GDH_RST_HR_HRBP_S,M02_P0200.GDH_RST_OPS_OC_S" />
                    <button name="action_psm_open_skip_hearing_wizard"
                        string="Không cần họp → Đề xuất" type="object" class="btn-secondary"
                        invisible="state != 'investigation'"
                        groups="M02_P0200.GDH_RST_HR_HRBP_S,M02_P0200.GDH_RST_OPS_OC_S" />

                    <!-- Bước 5: Hearing -->
                    <button name="action_psm_close_hearing" string="Kết thúc họp → Đề xuất"
                        type="object" class="oe_highlight" invisible="state != 'hearing'"
                        groups="M02_P0200.GDH_RST_HR_HRBP_S,M02_P0200.GDH_RST_OPS_OC_S" />

                    <!-- Bước 6: Proposal -->
                    <button name="action_psm_rgm_recheck_level" string="Xem xét lại" type="object"
                        class="btn-secondary"
                        invisible="state != 'proposal' or x_psm_discipline_level != 'company'"
                        groups="M02_P0200.GDH_OPS_STORE_RGM_M" />
                    <button name="action_psm_issue_decision" string="Ban hành Quyết định"
                        type="object" class="oe_highlight" invisible="state != 'proposal'"
                        groups="M02_P0200.GDH_OPS_STORE_RGM_M" />

                    <!-- Bước 7: Issued -->
                    <button name="action_psm_submit_for_approval"
                        string="Trình duyệt / Thông báo NV" type="object" class="oe_highlight"
                        invisible="state != 'issued'"
                        groups="M02_P0200.GDH_OPS_STORE_RGM_M,M02_P0200.GDH_RST_HR_HRBP_S,M02_P0200.GDH_RST_OPS_OC_S" />
                    <button name="action_psm_rehear" string="Cần họp lại" type="object"
                        class="btn-warning"
                        invisible="state != 'issued' or x_psm_discipline_level != 'company' or not x_psm_has_ceo_refused"
                        groups="M02_P0200.GDH_OPS_STORE_RGM_M" />

                    <!-- Bước 8: Approval (CEO) -->
                    <button name="action_psm_ceo_approve" string="CEO Phê duyệt" type="object"
                        class="btn-success" invisible="state != 'approval'"
                        groups="hr.group_hr_manager,M02_P0200.GDH_RST_MGMT_MANAGER_M" />
                    <button name="action_psm_open_ceo_reject_wizard" string="CEO Từ chối"
                        type="object" class="btn-danger" invisible="state != 'approval'"
                        groups="hr.group_hr_manager,M02_P0200.GDH_RST_MGMT_MANAGER_M" />

                    <!-- Bước 9: RGM manual employee confirmation -->
                    <button name="action_psm_open_rgm_manual_confirm_wizard"
                        string="RGM xác nhận hộ" type="object" class="btn-primary"
                        invisible="state != 'notified' or x_psm_is_accepted"
                        groups="M02_P0200.GDH_OPS_STORE_RGM_M" />

                    <!-- Bước 10: Active → Expire (thủ công) -->
                    <button name="action_psm_expire" string="Đánh dấu Hết hiệu lực" type="object"
                        class="btn-secondary" invisible="state != 'active'"
                        groups="M02_P0200.GDH_RST_HR_HRBP_S,hr.group_hr_manager" />

                    <button name="action_psm_cancel" string="Hủy" type="object"
                        class="btn-secondary" invisible="1" groups="M02_P0200.GDH_RST_HR_HRBP_S" />
                    <button name="action_psm_cancel" string="Hủy" type="object"
                        class="btn-secondary" invisible="1"
                        groups="M02_P0200.GDH_RST_OPS_OC_S,!M02_P0200.GDH_RST_HR_HRBP_S" />
                    <button name="action_psm_migrate_legacy_bridge" string="Bridge dữ liệu cũ"
                        type="object" class="btn-secondary" groups="hr.group_hr_manager"
                        invisible="1" />

                    <field name="state" widget="statusbar"
                        statusbar_visible="draft,under_review,level_determination,investigation,hearing,proposal,issued,approval,notified,active,expired" />
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_psm_schedule_meeting" type="object"
                            class="oe_stat_button" icon="fa-calendar">
                            <field name="x_psm_meeting_count" widget="statinfo" string="Meetings" />
                        </button>
                        <button name="action_psm_open_approval_request" type="object"
                            class="oe_stat_button" icon="fa-check-square-o"
                            invisible="not x_psm_approval_request_id">
                            <div class="o_stat_info">
                                <span class="o_stat_text">Approval</span>
                                <span class="o_stat_value">
                                    <field name="x_psm_approval_status" />
                                </span>
                            </div>
                        </button>
                        <button name="action_psm_open_explanation_survey_response" type="object"
                            class="oe_stat_button" icon="fa-list-alt"
                            invisible="1">
                            <div class="o_stat_info">
                                <span class="o_stat_text">Survey</span>
                                <span class="o_stat_value">
                                    <field name="x_psm_explanation_survey_state" />
                                </span>
                            </div>
                        </button>
                        <button name="action_psm_open_feedback_survey_response" type="object"
                            class="oe_stat_button" icon="fa-commenting-o"
                            invisible="1">
                            <div class="o_stat_info">
                                <span class="o_stat_text">Feedback</span>
                                <span class="o_stat_value">
                                    <field name="x_psm_feedback_survey_state" />
                                </span>
                            </div>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1" />
                        </h1>
                    </div>
                    <group string="ĐẠI DIỆN CÔNG TY">
                        <group>
                            <field name="x_psm_company_rep_id" />
                            <field name="x_psm_rep_department_id" />
                            <field name="x_psm_rep_job_id" />
                            <field name="x_psm_rep_level" />
                        </group>
                        <group>
                            <field name="x_psm_date" string="Ngày thực hiện" />
                            <field name="x_psm_discipline_purpose" widget="radio"
                                options="{'horizontal': true}" />
                        </group>
                    </group>

                    <group string="NGƯỜI LAO ĐỘNG">
                        <group>
                            <field name="x_psm_employee_domain" invisible="1" />
                            <field name="x_psm_employee_id" domain="x_psm_employee_domain" />
                            <field name="x_psm_emp_barcode" string="Mã số nhân viên" readonly="1" />
                        </group>
                        <group>
                            <field name="x_psm_emp_department_id" />
                            <field name="x_psm_emp_job_id" />
                            <field name="x_psm_emp_level" />
                        </group>
                    </group>

                    <group string="NGƯỜI LÀM CHỨNG">
                        <group>
                            <field name="x_psm_witness_id" domain="x_psm_employee_domain"
                                readonly="state not in ('draft', 'under_review')" />
                        </group>
                        <group>
                            <field name="x_psm_witness_department_id" readonly="1"
                                invisible="not x_psm_witness_id" />
                            <field name="x_psm_witness_job_id" readonly="1"
                                invisible="not x_psm_witness_id" />
                            <field name="x_psm_witness_level" readonly="1"
                                invisible="not x_psm_witness_id" />
                        </group>
                    </group>

                    <group string="XÁC ĐỊNH VI PHẠM">
                        <group>
                            <field name="x_psm_violation_category_id" />
                            <field name="x_psm_violation_type" />
                        </group>
                        <group>
                            <field name="x_psm_discipline_level" readonly="1"
                                invisible="not x_psm_discipline_level" />
                            <field name="x_psm_is_repeat_offense" invisible="1" />
                            <field name="x_psm_rgm_is_repeat" invisible="1" />
                            <field name="x_psm_related_records_count"
                                invisible="not x_psm_is_repeat_offense" />
                        </group>
                    </group>

                    <div class="alert alert-danger" role="alert"
                        invisible="not x_psm_is_repeat_offense">
                        <strong>CẢNH BÁO:</strong> Nhân viên này đã có <field
                            name="x_psm_related_records_count" /> vi phạm trước đó chưa hết thời hạn
                        lưu trữ. </div>

                    <group string="Hình thức Kỷ luật">
                        <group>
                            <field name="x_psm_action_id"
                                domain="[('x_psm_level', '=', x_psm_discipline_level)]"
                                readonly="state not in ('proposal', 'under_review', 'issued')"
                                required="state == 'issued'" />
                            <field name="x_psm_previous_record_id"
                                invisible="not x_psm_previous_record_id" />
                            <field name="x_psm_skip_hearing_reason" readonly="1"
                                invisible="not x_psm_skip_hearing_reason" />
                        </group>
                        <group>
                            <div class="alert alert-warning" role="alert"
                                invisible="not x_psm_previous_record_id">
                                Đây là vi phạm TÁI PHẠM - leo thang từ bản ghi cũ.
                            </div>
                        </group>
                    </group>

                    <group string="Phê duyệt"
                        invisible="x_psm_discipline_level != 'company' and not x_psm_approval_request_id">
                        <div class="alert alert-warning" role="alert" colspan="2"
                            invisible="state != 'issued' or not x_psm_approval_refuse_reason">
                            <strong>CEO từ chối:</strong>
                            <field name="x_psm_approval_refuse_reason" readonly="1" nolabel="1" />
                        </div>
                        <group>
                            <field name="x_psm_approval_request_id" readonly="1" />
                            <field name="x_psm_approval_status" readonly="1" />
                        </group>
                        <group>
                            <field name="x_psm_approval_requested_date" readonly="1" />
                            <field name="x_psm_approval_completed_date" readonly="1" />
                            <field name="x_psm_approval_refuse_reason" readonly="1"
                                invisible="not x_psm_approval_refuse_reason" />
                        </group>
                    </group>

                    <group string="Thời hạn Hiệu lực"
                        invisible="state not in ('active', 'expired', 'notified', 'issued')">
                        <group>
                            <field name="x_psm_issued_date" readonly="1" />
                            <field name="x_psm_start_date" />
                            <field name="x_psm_end_date" readonly="1" />
                        </group>
                        <group>
                            <label for="x_psm_days_remaining" string="Ngày hiệu lực còn lại" />
                            <div class="d-flex align-items-center">
                                <field name="x_psm_days_remaining"
                                    class="oe_inline fw-bold text-danger" style="font-size: 24px;" />
                                <span class="ms-2">ngày</span>
                            </div>
                        </group>
                    </group>

                    <group string="Biên bản họp &amp; Quyết định"
                        invisible="x_psm_discipline_level != 'company'">
                        <group string="1. Hồ sơ Biên bản">
                            <label for="x_psm_latest_meeting_id" string="Linked to" />
                            <field name="x_psm_latest_meeting_id" widget="many2one" nolabel="1"
                                readonly="1" options="{'no_create': True, 'no_open': False}" />
                            <field name="x_psm_meeting_date" readonly="state not in ('investigation', 'hearing')" />
                            <field name="x_psm_meeting_notes" readonly="state not in ('investigation', 'hearing')" />
                            <field name="x_psm_meeting_attachment" invisible="1" />
                            
                            <label for="x_psm_meeting_attachment_ids" string="Biên bản xử lý kỷ luật" />
                            <div>
                                <field name="x_psm_meeting_attachment_ids" widget="many2many_binary" 
                                       readonly="state not in ('investigation', 'hearing')" />
                                <a href="/M02_P0215/static/src/templates/mau_bien_ban_xu_ly_ky_luat.docx" 
                                   class="btn btn-link btn-sm" target="_blank">
                                    <i class="fa fa-download"/> Tải mẫu
                                </a>
                            </div>

                        </group>
                    </group>

                    <group string="Bồi thường (Finance)"
                        invisible="x_psm_discipline_level != 'company'">
                        <group>
                            <field name="x_psm_has_compensation" />
                            <field name="x_psm_compensation_amount"
                                invisible="not x_psm_has_compensation"
                                required="x_psm_has_compensation" />
                            <field name="currency_id" invisible="1" />
                        </group>
                        <group invisible="not x_psm_has_compensation">
                            <label for="x_psm_compensation_minutes_ids" string="Biên bản xử lý bồi thường" />
                            <div>
                                <field name="x_psm_compensation_minutes_ids" widget="many2many_binary" 
                                       readonly="state not in ('investigation', 'hearing')" />
                                <a href="/M02_P0215/static/src/templates/mau_bien_ban_xu_ly_boi_thuong.docx" 
                                   class="btn btn-link btn-sm" target="_blank">
                                    <i class="fa fa-download"/> Tải mẫu
                                </a>
                            </div>
                        </group>
                    </group>
                    <group string="2. Quyết định (Trình CEO)"
                        invisible="x_psm_discipline_level != 'company'">
                        <group>
                            <label for="x_psm_disciplinary_decision_attachment"
                                string="Quyết định xử lý kỷ luật" />
                            <div>
                                <field name="x_psm_disciplinary_decision_filename" invisible="1" />
                                <field name="x_psm_disciplinary_decision_attachment"
                                    widget="binary"
                                    filename="x_psm_disciplinary_decision_filename"
                                    readonly="state not in ('issued', 'hearing', 'approval')" />
                                <a href="/M02_P0215/static/src/templates/mau_quyet_dinh_xu_ly_ky_luat.docx" 
                                   class="btn btn-link btn-sm" target="_blank">
                                    <i class="fa fa-download"/> Tải mẫu
                                </a>
                            </div>

                            <label for="x_psm_compensation_decision_attachment"
                                string="Quyết định đền bù" invisible="not x_psm_has_compensation" />
                            <div invisible="not x_psm_has_compensation">
                                <field name="x_psm_compensation_decision_filename" invisible="1" />
                                <field name="x_psm_compensation_decision_attachment"
                                    widget="binary"
                                    filename="x_psm_compensation_decision_filename"
                                    readonly="state not in ('issued', 'hearing', 'approval')" />
                                <a href="/M02_P0215/static/src/templates/mau_quyet_dinh_xu_ly_boi_thuong.docx" 
                                   class="btn btn-link btn-sm" target="_blank">
                                    <i class="fa fa-download"/> Tải mẫu
                                </a>
                            </div>
                        </group>
                    </group>

                    <separator
                        string="I. Mô tả tình huống vi phạm/không hoàn thành công việc được giao" />
                    <field name="x_psm_section_i_description"
                        placeholder="Nhập mô tả chi tiết sự việc..." />

                    <separator string="II. Phản hồi/ Ý kiến của nhân viên" />
                    <field name="x_psm_section_ii_feedback"
                        placeholder="Ý kiến từ phía nhân viên..." />

                    <separator
                        string="III. Xác định hành vi vi phạm/không hoàn thành công việc được giao &amp; xác nhận của nhân viên" />
                    <field name="x_psm_section_iii_identification" placeholder="Kết luận vi phạm..." />

                    <separator string="IV. Hai bên đồng ý với những nội dung sau" />
                    <field name="x_psm_section_iv_agreement"
                        placeholder="Các cam kết và thỏa thuận..." />

                    <notebook>
                        <page string="Bản tường trình (Hình ảnh)" name="physical_explanation">
                            <group>
                                <field name="x_psm_explanation_image_ids" widget="many2many_binary"
                                    string="Tải ảnh bản tường trình giấy" />
                            </group>
                            <group>
                                <p class="text-muted">Dành cho trường hợp nhân viên viết bản giấy
                                    trực tiếp tại cửa hàng.</p>
                            </group>
                        </page>
                        <page string="Chữ ký &amp; Phê duyệt" name="signatures">
                            <group>
                                <group string="Công ty">
                                    <field name="x_psm_manager_signature" widget="signature"
                                        readonly="state not in ('draft', 'under_review')" />
                                    <field name="x_psm_manager_signature_date" readonly="1" />
                                </group>
                                <group string="Nhân viên">
                                    <field name="x_psm_employee_signature" widget="signature"
                                        readonly="state not in ('draft', 'under_review')" />
                                    <field name="x_psm_employee_signature_date" readonly="1" />
                                </group>
                                <group string="Người làm chứng">
                                    <field name="x_psm_witness_signature" widget="signature"
                                        readonly="state not in ('draft', 'under_review')"
                                        options="{'size': [0, 100]}" />
                                    <field name="x_psm_witness_signature_date" readonly="1" />
                                </group>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter />
            </form>
        </field>
    </record>

    <!-- Kanban View -->
    <record id="view_psm_hr_discipline_record_kanban" model="ir.ui.view">
        <field name="name">hr.discipline.record.kanban</field>
        <field name="model">x_psm.hr.discipline.record</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" class="o_kanban_mobile" sample="1">
                <field name="name" />
                <field name="x_psm_employee_id" />
                <field name="state" />
                <field name="x_psm_is_repeat_offense" />
                <field name="x_psm_violation_category_id" />
                <field name="x_psm_discipline_level" />
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_global_click">
                            <div class="oe_kanban_content">
                                <div class="o_kanban_record_top">
                                    <div class="o_kanban_record_headings">
                                        <strong class="o_kanban_record_title">
                                            <field name="name" />
                                        </strong>
                                    </div>
                                    <div class="o_dropdown_kanban dropdown">
                                        <a class="dropdown-toggle o-no-caret btn" role="button"
                                            data-bs-toggle="dropdown" data-bs-display="static"
                                            href="#" aria-label="Dropdown menu"
                                            title="Dropdown menu">
                                            <span class="fa fa-ellipsis-v" />
                                        </a>
                                        <div class="dropdown-menu" role="menu">
                                            <a role="menuitem" type="edit" class="dropdown-item">
                                                Edit</a>
                                            <a role="menuitem" type="delete" class="dropdown-item">
                                                Delete</a>
                                        </div>
                                    </div>
                                </div>
                                <div class="o_kanban_record_body">
                                    <div>
                                        <field name="x_psm_employee_id" />
                                    </div>
                                    <div class="text-muted">
                                        <field name="x_psm_violation_category_id" />
                                    </div>
                                    <div class="d-flex flex-wrap gap-1">
                                        <div t-if="record.x_psm_is_repeat_offense.raw_value"
                                            class="badge text-bg-danger mt-1">⚠️ Tái phạm</div>
                                        <div
                                            t-if="record.x_psm_discipline_level.raw_value == 'store'"
                                            class="badge text-bg-info mt-1">🏪 Store</div>
                                        <div
                                            t-if="record.x_psm_discipline_level.raw_value == 'company'"
                                            class="badge text-bg-warning mt-1">🏢 Company</div>
                                    </div>
                                </div>
                                <div class="o_kanban_record_bottom mt-2">
                                    <div class="oe_kanban_bottom_left">
                                        <field name="activity_ids" widget="kanban_activity" />
                                    </div>
                                    <div class="oe_kanban_bottom_right">
                                        <field name="state" widget="label_selection"
                                            options="{'classes': {'draft': 'default', 'active': 'success', 'expired': 'warning'}}" />
                                    </div>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_psm_hr_discipline_record_search" model="ir.ui.view">
        <field name="name">hr.discipline.record.search</field>
        <field name="model">x_psm.hr.discipline.record</field>
        <field name="arch" type="xml">
            <search string="Search Disciplinary Records">
                <field name="name" />
                <field name="x_psm_employee_id" />
                <field name="x_psm_violation_type" />
                <filter string="My Records" name="my_records"
                    domain="[('x_psm_employee_id.user_id', '=', uid)]" />
                <filter string="Chờ RGM Xem xét" name="to_review"
                    domain="[('state', '=', 'under_review')]" />
                <filter string="Đang Xác minh (Company)" name="investigation"
                    domain="[('state', '=', 'investigation')]" />
                <filter string="Đang Hiệu lực" name="active" domain="[('state', '=', 'active')]" />
                <separator />
                <filter string="Records (Store Level)" name="level_store"
                    domain="[('x_psm_discipline_level', '=', 'store')]" />
                <filter string="Reports (Store Level)" name="action_level_store"
                    domain="[('x_psm_action_id.x_psm_level', '=', 'store')]" />
                <filter string="Records (Company Level)" name="level_company"
                    domain="[('x_psm_discipline_level', '=', 'company')]" />
                <separator />
                <!-- Odoo 19: No <group string="Group By"> tags here -->
                <filter string="Employee" name="group_by_employee"
                    context="{'group_by': 'x_psm_employee_id'}" />
                <filter string="State" name="group_by_state" context="{'group_by': 'state'}" />
                <filter string="Violation Category" name="group_by_category"
                    context="{'group_by': 'x_psm_violation_category_id'}" />
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_psm_hr_discipline_record_main" model="ir.actions.act_window">
        <field name="name">Disciplinary Records</field>
        <field name="res_model">x_psm.hr.discipline.record</field>
        <field name="view_mode">kanban,list,form</field>
    </record>

    <!-- Menu -->
    <menuitem id="menu_psm_hr_discipline_record_main" name="Records"
        parent="menu_psm_hr_discipline_root" action="action_psm_hr_discipline_record_main"
        sequence="1" />

    <record id="view_psm_hr_discipline_record_form_internal_ux" model="ir.ui.view">
        <field name="name">hr.discipline.record.form.internal.ux</field>
        <field name="model">x_psm.hr.discipline.record</field>
        <field name="inherit_id" ref="view_psm_hr_discipline_record_form" />
        <field name="arch" type="xml">
            <xpath expr="//div[@class='oe_title']" position="after">
                <div class="row g-3 mb-4" invisible="not x_psm_employee_id and not x_psm_violation_category_id and not x_psm_action_id">
                    <div class="col-12 col-sm-6 col-xl-3">
                        <div class="p-3 border rounded bg-white shadow-sm h-100 overflow-hidden">
                            <div class="text-muted text-uppercase small fw-semibold mb-1">Nhân viên</div>
                            <div class="x_psm_summary_value text-break">
                                <field name="x_psm_employee_id" nolabel="1" readonly="1" />
                            </div>
                        </div>
                    </div>
                    <div class="col-12 col-sm-6 col-xl-3">
                        <div class="p-3 border rounded bg-white shadow-sm h-100 overflow-hidden">
                            <div class="text-muted text-uppercase small fw-semibold mb-1">Vi phạm</div>
                            <div class="x_psm_summary_value text-break">
                                <field name="x_psm_violation_category_id" nolabel="1" readonly="1" />
                            </div>
                        </div>
                    </div>
                    <div class="col-12 col-sm-6 col-xl-3">
                        <div class="p-3 border rounded bg-white shadow-sm h-100 overflow-hidden">
                            <div class="text-muted text-uppercase small fw-semibold mb-1">Hình thức</div>
                            <div class="x_psm_summary_value text-break">
                                <field name="x_psm_action_id" nolabel="1" readonly="1" />
                            </div>
                        </div>
                    </div>
                    <div class="col-12 col-sm-6 col-xl-3">
                        <div class="p-3 border rounded bg-white shadow-sm h-100 overflow-hidden">
                            <div class="text-muted text-uppercase small fw-semibold mb-1">Ngày</div>
                            <div class="x_psm_summary_value text-break">
                                <field name="x_psm_date" nolabel="1" readonly="1" />
                            </div>
                        </div>
                    </div>
                </div>
            </xpath>
        </field>
    </record>

</odoo>

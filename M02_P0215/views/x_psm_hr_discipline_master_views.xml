<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Violation Category Views -->
    <record id="view_psm_hr_discipline_violation_category_tree" model="ir.ui.view">
        <field name="name">hr.discipline.violation.category.tree</field>
        <field name="model">x_psm.hr.discipline.violation.category</field>
        <field name="arch" type="xml">
            <list string="Violation Categories">
                <field name="x_psm_code"/>
                <field name="name"/>
            </list>
        </field>
    </record>

    <record id="view_psm_hr_discipline_violation_category_form" model="ir.ui.view">
        <field name="name">hr.discipline.violation.category.form</field>
        <field name="model">x_psm.hr.discipline.violation.category</field>
        <field name="arch" type="xml">
            <form string="Violation Category">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="x_psm_code"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_psm_hr_discipline_violation_category" model="ir.actions.act_window">
        <field name="name">Violation Categories</field>
        <field name="res_model">x_psm.hr.discipline.violation.category</field>
        <field name="view_mode">list,form</field>
    </record>


    <!-- Violation Types Views -->
    <record id="view_psm_hr_discipline_violation_type_tree" model="ir.ui.view">
        <field name="name">hr.discipline.violation.type.tree</field>
        <field name="model">x_psm.hr.discipline.violation.type</field>
        <field name="arch" type="xml">
            <list string="Violation Types">
                <field name="name"/>
                <field name="x_psm_category_id"/>
                <field name="x_psm_severity" widget="badge" decoration-success="x_psm_severity == 'minor'" decoration-danger="x_psm_severity == 'major'"/>
                <field name="x_psm_improvement_period"/>
                <field name="x_psm_max_repeats"/>
            </list>
        </field>
    </record>

    <record id="view_psm_hr_discipline_violation_type_form" model="ir.ui.view">
        <field name="name">hr.discipline.violation.type.form</field>
        <field name="model">x_psm.hr.discipline.violation.type</field>
        <field name="arch" type="xml">
            <form string="Violation Type">
                <sheet>
                    <group>
                        <group>
                            <field name="x_psm_category_id"/>
                            <field name="name"/>
                        </group>
                        <group>
                            <field name="x_psm_severity"/>
                            <field name="x_psm_improvement_period"/>
                            <field name="x_psm_max_repeats"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_psm_hr_discipline_violation_type" model="ir.actions.act_window">
        <field name="name">Violation Types</field>
        <field name="res_model">x_psm.hr.discipline.violation.type</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Disciplinary Actions Views -->
    <record id="view_psm_hr_discipline_action_tree" model="ir.ui.view">
        <field name="name">hr.discipline.action.tree</field>
        <field name="model">x_psm.hr.discipline.action</field>
        <field name="arch" type="xml">
            <list string="Disciplinary Actions">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="x_psm_level"/>
                <field name="x_psm_form_code"/>
                <field name="x_psm_requires_finance_check"/>
            </list>
        </field>
    </record>

    <record id="view_psm_hr_discipline_action_form" model="ir.ui.view">
        <field name="name">hr.discipline.action.form</field>
        <field name="model">x_psm.hr.discipline.action</field>
        <field name="arch" type="xml">
            <form string="Disciplinary Action">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="x_psm_level"/>
                            <field name="x_psm_form_code"/>
                            <field name="x_psm_allowed_job_ids" widget="many2many_tags"/>
                        </group>
                        <group>
                            <field name="sequence"/>
                            <field name="x_psm_validity_months"/>
                            <field name="x_psm_next_action_id"/>
                            <field name="x_psm_has_penalty"/>
                            <field name="x_psm_requires_finance_check"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_psm_hr_discipline_action" model="ir.actions.act_window">
        <field name="name">Disciplinary Actions</field>
        <field name="res_model">x_psm.hr.discipline.action</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Menus -->
    <menuitem id="menu_psm_hr_discipline_root" name="Discipline" sequence="10" web_icon="M02_P0215,static/description/consistency.png"/>
    
    <menuitem id="menu_psm_hr_discipline_configuration" name="Configuration" parent="menu_psm_hr_discipline_root" sequence="100"/>
    
    <menuitem id="menu_psm_hr_discipline_violation_category" name="Violation Categories" parent="menu_psm_hr_discipline_configuration" action="action_psm_hr_discipline_violation_category" sequence="1"/>
    <menuitem id="menu_psm_hr_discipline_violation_type" name="Violation Types" parent="menu_psm_hr_discipline_configuration" action="action_psm_hr_discipline_violation_type" sequence="2"/>
    <menuitem id="menu_psm_hr_discipline_action" name="Disciplinary Actions" parent="menu_psm_hr_discipline_configuration" action="action_psm_hr_discipline_action" sequence="3"/>

</odoo>

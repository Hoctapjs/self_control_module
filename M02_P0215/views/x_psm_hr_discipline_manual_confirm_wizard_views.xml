<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_psm_hr_discipline_manual_confirm_wizard_form" model="ir.ui.view">
        <field name="name">hr.discipline.manual.confirm.wizard.form</field>
        <field name="model">x_psm.hr.discipline.manual.confirm.wizard</field>
        <field name="arch" type="xml">
            <form string="RGM Manual Confirmation">
                <group>
                    <field name="x_psm_record_id" invisible="1"/>
                    <field name="x_psm_start_date"/>
                </group>
                <footer>
                    <button name="action_psm_confirm" string="Confirm" type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Sequence for PIF ID (PIF/2026/0001) -->
        <record id="seq_pif_object" model="ir.sequence">
            <field name="name">PIF Execution ID</field>
            <field name="code">x_psm_pif_object</field>
            <field name="prefix">PIF/%(year)s/</field>
            <field name="padding">4</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
        </record>
        <!-- Sequence for Finished Good WRIN (FG-2026-0001) -->
        <record id="seq_product_wrin_finished" model="ir.sequence">
            <field name="name">Finished Good WRIN</field>
            <field name="code">product.wrin.finished</field>
            <field name="prefix">FG-%(year)s-</field>
            <field name="padding">4</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
        </record>
    </data>
</odoo>

<odoo>
    <data noupdate="1">
         <record id="pif_import_dir_param" model="ir.config_parameter">
            <field name="key">m08_p0801.pif_import_dir</field>
            <field name="value">/mnt/file</field>
        </record>

         <record id="pif_platform_fc" model="x_psm_pif_platform">
            <field name="name">Front Counter</field>
            <field name="code">FC</field>
            <field name="sequence">10</field>
        </record>

         <record id="pif_platform_sok" model="x_psm_pif_platform">
            <field name="name">Self Ordering Kiosk</field>
            <field name="code">SOK</field>
            <field name="sequence">20</field>
        </record>

         <record id="pif_platform_dt" model="x_psm_pif_platform">
            <field name="name">Drive Thru</field>
            <field name="code">DT</field>
            <field name="sequence">30</field>
        </record>

         <record id="pif_platform_wt" model="x_psm_pif_platform">
            <field name="name">Window Takeaway</field>
            <field name="code">WT</field>
            <field name="sequence">40</field>
        </record>

         <record id="pif_platform_mccafe" model="x_psm_pif_platform">
            <field name="name">McCafe</field>
            <field name="code">MCCAFE</field>
            <field name="sequence">50</field>
        </record>

         <record id="pif_platform_digital" model="x_psm_pif_platform">
            <field name="name">Digital</field>
            <field name="code">DIGITAL</field>
            <field name="sequence">60</field>
        </record>

         <record id="approval_category_data_pif" model="approval.category">
            <field name="name">Product Initiation Form (PIF)</field>
            <field name="description">Request to create a new Product Initiation Form.</field>
            <field name="x_psm_0801_is_pif" eval="True"/>
            <!-- Standard Approval Fields to enable -->
            <field name="has_product">no</field>

            <field name="has_location">no</field>
        </record>
    </data>
</odoo>
